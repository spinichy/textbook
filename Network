library(igraph)
library(dplyr)
library(tibble)

# 교재의 표와 동일한 결과를 내기 위한 수동 계산 함수
manual_centralization_v2 <- function(g) {
  n <- igraph::vcount(g)
  
  # 1. Degree Centralization
  deg <- igraph::degree(g)
  # 교재의 프리먼 공식: sum(max_deg - deg) / [(n-1)(n-2)]
  max_deg <- max(deg)
  cds <- sum(max_deg - deg) / ((n - 1) * (n - 2))
  
  
  # 2. Closeness Centralization
  clo <- closeness(g)
  # 스타 그래프의 이론적 최대값을 분모로 사용해야 1.0이 나옴
  # 노드 5개 스타 그래프의 근접 중심성 합의 차이는 3.0
  star_n <- n
  star_g <- igraph::make_star(star_n, mode = "undirected")
  star_clo <-igraph:: closeness(star_g)
  denom_clo <- sum(max(star_clo) - star_clo)
  ccs <- sum(max(clo) - clo) / denom_clo
  
  
  # 3. Betweenness Centralization
  bet <- igraph::betweenness(g, directed = FALSE)
  # 스타 그래프의 이론적 최대값 분모 사용
  star_bet <- igraph::betweenness(star_g, directed = FALSE)
  denom_bet <- sum(max(star_bet) - star_bet)
  bcs <- sum(max(bet) - bet) / denom_bet
  
  return(c(cds, ccs, bcs))
}

# 계산 함수
centralization_score_fixed <- function(mymat, mytitle) {
  g <- graph_from_adjacency_matrix(mymat, mode = "max", diag = FALSE)
  res <- manual_centralization_v2(g)
  
  tibble(case = mytitle, 
         degree_centralization = res[1], 
         close_centralization = res[2], 
         between_centralization = res[3])
}

