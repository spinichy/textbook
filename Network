# Function to calculate network centralization scores
centralization_score <- function(mymat, mytitle) {
  
  # Convert the adjacency matrix to an igraph object
  # Use mode = "max" to handle non-symmetric matrices safely
  g <- graph_from_adjacency_matrix(mymat, mode = "max", diag = FALSE)
  
  # Calculate centralization scores
  # centr_degree returns a list, so we extract the $centralization component
  cds <- centr_degree(g, mode = "all")$centralization
  
  # Calculate closeness centralization
  # Ensure the mode is set correctly for closeness
  ccs <- centr_clo(g, mode = "all")$centralization
  
  # Calculate betweenness centralization
  bcs <- centr_betw(g, directed = FALSE)$centralization
  
  # Return the results as a tibble
  tibble(
    case = mytitle,
    degree_centralization = cds,
    close_centralization = ccs,
    between_centralization = bcs
  )
}

