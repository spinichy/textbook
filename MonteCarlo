# Bartlett Decomposition Function
# n: degrees of freedom, p: dimension
generate_wishart_bartlett <- function(n, p) {
  # 1. Create an empty p x p matrix
  T_mat <- matrix(0, nrow = p, ncol = p)
  
  # 2. Fill the matrix based on Bartlett's decomposition
  for (i in 1:p) {
    for (j in 1:i) {
      if (i == j) {
        # Diagonal elements: square root of Chi-squared distribution
        # df decreases as the row index increases: n - i + 1
        T_mat[i, j] <- sqrt(rchisq(1, df = n - i + 1))
      } else {
        # Off-diagonal elements: Standard Normal distribution
        T_mat[i, j] <- rnorm(1, mean = 0, sd = 1)
      }
    }
  }
  
  # 3. Calculate W = T %*% t(T)
  W <- T_mat %*% t(T_mat)
  return(list(T = T_mat, W = W))
}

