# Function to draw Surface and Contour plots
draw_bvn <- function(mu, sigma_sq, rho, title_suffix) {
  # Create covariance matrix
  # sigma_sq is a vector c(var_x, var_y)
  cov_matrix <- matrix(c(sigma_sq[1], rho * sqrt(prod(sigma_sq)),
                         rho * sqrt(prod(sigma_sq)), sigma_sq[2]), nrow = 2)
  
  # Define grid for plotting
  x <- seq(mu[1] - 3 * sqrt(sigma_sq[1]), mu[1] + 3 * sqrt(sigma_sq[1]), length.out = 50)
  y <- seq(mu[2] - 3 * sqrt(sigma_sq[2]), mu[2] + 3 * sqrt(sigma_sq[2]), length.out = 50)
  z <- outer(x, y, function(x, y) dmvnorm(cbind(x, y), mean = mu, sigma = cov_matrix))
  
  # Draw Surface Plot
  persp(x, y, z, phi = 30, theta = 30, col = "lightblue", shade = 0.5,
        main = paste("Surface Plot:", title_suffix),
        xlab = "X", ylab = "Y", zlab = "Density")
  
  # Draw Contour Plot
  contour(x, y, z, main = paste("Contour Plot:", title_suffix),
          xlab = "X", ylab = "Y", col = "blue", lwd = 1.5)
}

