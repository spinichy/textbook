# 1. Define a symmetric matrix
A <- matrix(c(4, 2, 2,
              2, 5, 3,
              2, 3, 6), nrow = 3, byrow = TRUE)

# 2. Power Iteration function to find the largest eigenvalue/vector
# This finds the dominant eigenvalue and its corresponding eigenvector
power_iteration <- function(mat, iterations = 100) {
  n <- nrow(mat)
  # Initialize a random vector
  v <- rep(1, n)
  
  for (i in 1:iterations) {
    # Matrix-vector multiplication
    v_new <- mat %*% v
    # Normalize the vector to prevent overflow
    v <- v_new / sqrt(sum(v_new^2))
  }
  
  # Rayleigh quotient to find the eigenvalue: (v^T * A * v) / (v^T * v)
  eigenvalue <- as.numeric(t(v) %*% mat %*% v)
  
  return(list(value = eigenvalue, vector = v))
}

# 3. Deflation process to find all eigenvalues
get_all_eigen <- function(mat) {
  n <- nrow(mat)
  current_mat <- mat
  evals <- numeric(n)
  evecs <- matrix(0, n, n)
  
  for (k in 1:n) {
    # Find the dominant eigenvalue of the current matrix
    res <- power_iteration(current_mat)
    evals[k] <- res$value
    evecs[, k] <- res$vector
    
    # Deflation: Remove the influence of the found eigenvalue
    # A_next = A - lambda * (v %*% v^T)
    current_mat <- current_mat - res$value * (res$vector %*% t(res$vector))
  }
  
  return(list(values = evals, vectors = evecs))
}

