# Linear Congruential Generator (LCG) Implementation
# Parameters satisfy Hull-Dobell Theorem for Full Period M

create_lcg <- function(seed, n = 10) {
  # 1. Parameters setting
  # M = 2^32: M is a multiple of 4
  # a = 1103515245: (a-1) is a multiple of 4, and divisible by all prime factors of M (which is 2)
  # c = 12345: c and M are relatively prime (12345 is odd, M is a power of 2)
  
  m <- 2^32
  a <- 1103515245
  c <- 12345
  
  # Initialize vector to store random numbers
  random_numbers <- numeric(n)
  current_x <- seed
  
  for (i in 1:n) {
    # LCG Formula: X_{n+1} = (aX_n + c) mod M
    # Using double precision to handle large integer multiplication before modulo
    current_x <- (a * current_x + c) %% m
    
    # Scaling to [0, 1) range for general utility
    random_numbers[i] <- current_x / m
  }
  
  return(random_numbers)
}

# Example Usage: Generate 5 random numbers starting with seed 42
my_random_samples <- create_lcg(seed = 42, n = 5)
print(my_random_samples)


