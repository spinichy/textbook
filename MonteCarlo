# Function to estimate Beta(3, 3) cdf using Monte Carlo integration
mc_beta_cdf <- function(x, n = 10000) {
  # Generate n random uniform numbers between 0 and x
  u <- runif(n, min = 0, max = x)
  
  # Calculate the Beta(3, 3) density values for each u
  # The density f(y) = (1/B(3,3)) * y^2 * (1-y)^2
  # Beta function B(3,3) = factorial(2)*factorial(2)/factorial(5) = 4/120 = 1/30
  # So f(y) = 30 * y^2 * (1-y)^2
  y_values <- 30 * u^2 * (1 - u)^2
  
  # The estimate is the sample mean multiplied by the interval width x
  return(mean(y_values) * x)
}

