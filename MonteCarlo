# Required libraries
# install.packages(c("nortest", "circular"))
library(nortest)   # For Anderson-Darling and Cramér-von Mises tests
library(circular)  # For Rayleigh test
library(ggplot2)   # For visualization
library(goftest)   # For Cramér-von Mises test


# 1. Data Generation
set.seed(123)
n <- 100
unif_data <- runif(n, min = 0, max = 1)  # Perfectly uniform data
norm_data <- rnorm(n, mean = 0.5, sd = 0.1) # Not uniform data (normal)

# ---------------------------------------------------------
# 2. Kolmogorov-Smirnov (K-S) Test
# ks.test compares the data to a cumulative distribution function (punif)
ks_unif <- ks.test(unif_data, "punif", 0, 1)
ks_norm <- ks.test(norm_data, "punif", 0, 1)

print(paste("K-S Test (Uniform Data) p-value:", round(ks_unif$p.value, 4)))
print(paste("K-S Test (Normal Data) p-value:", round(ks_norm$p.value, 4)))


# ---------------------------------------------------------
# 3. Cramér-von Mises (폰 미제스) Test
# cvm.test from 'nortest' package
cvm_unif <- goftest::cvm.test(unif_data, "punif")
cvm_norm <- goftest::cvm.test(norm_data, "punif")

print(paste("Fixed CVM Test p-value:", round(cvm_unif$p.value, 4)))
print(paste("Fixed CVM Test p-value:", round(cvm_norm$p.value, 4)))

# ---------------------------------------------------------
# 4. Anderson-Darling Test
# ad.test from 'nortest' package

ad_unif <- ad.test(unif_data)
ad_norm <- ad.test(norm_data)

print(paste("A-D Test (Uniform Data) p-value:", round(ad_unif$p.value, 4)))
print(paste("A-D Test (Normal Data) p-value:", round(ad_norm$p.value, 4)))

# ---------------------------------------------------------
# 5. Chi-Squared Goodness-of-Fit Test
# Binning the data into 10 intervals
bins <- seq(0, 1, length.out = 11)
observed_unif <- table(cut(unif_data, breaks = bins))
expected_probs <- rep(1/10, 10)

chi_unif <- chisq.test(observed_unif, p = expected_probs)
print(paste("Chi-sq Test (Uniform Data) p-value:", round(chi_unif$p.value, 4)))


# ---------------------------------------------------------
# 6. Rayleigh Test (Circular Uniformity)
# Convert data to circular objects (0 to 2*pi radians)
circ_unif <- as.circular(runif(n, 0, 2*pi), 
                         units = "radians", 
                         type = "angles", 
                         template = "none",
                         modulo = "asis", 
                         zero = 0, 
                         rotation = "counter")
rayleigh_res <- rayleigh.test(circ_unif)
print(paste("Rayleigh Test p-value:", round(rayleigh_res$p.value, 4)))
plot(circ_unif)

