# 1. Function to generate random samples from a Normal Mixture Model
rmix_norm <- function(n, p1, mu1 = 0, mu2 = 3, sd1 = 1, sd2 = 1) {
  # Determine which component to sample from (0 for N(0,1), 1 for N(3,1))
  selection <- rbinom(n, 1, 1 - p1)
  
  # Generate samples based on the selection
  samples <- ifelse(selection == 0, 
                    rnorm(n, mean = mu1, sd = sd1), 
                    rnorm(n, mean = mu2, sd = sd2))
  return(samples)
}

