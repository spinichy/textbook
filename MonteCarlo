#10.2 Decompostion: QR



# QR Decomposition using Gram-Schmidt Process (Manual Simulation)
# Mathematical Proof: A = QR, where Q is orthonormal and R is upper triangular.

# 1. Define a 3x3 invertible matrix A
A <- matrix(c(1, 1, 0, 
              1, 0, 1, 
              0, 1, 1), nrow = 3, byrow = TRUE)

n <- ncol(A)
m <- nrow(A)

# Initialize Q and R with zeros
# Q will store orthonormal basis vectors
# R will store coordinates (projections) in the new basis
Q <- matrix(0, m, n)
R <- matrix(0, n, n)

# --- STEP 1: Process Column 1 ---
# Objective: Find the first unit vector q1 from a1.
# v1 = a1 (Initial vector)
v1 <- A[, 1]

# R[1,1] = ||v1|| (Norm of the vector)
# Proof: r_ii is the length of the orthogonal component.
R[1, 1] <- sqrt(sum(v1^2))

# q1 = v1 / ||v1|| (Normalization)
# Proof: Every basis vector in Q must have unit length.
Q[, 1] <- v1 / R[1, 1]


# --- STEP 2: Process Column 2 ---
# Objective: Find q2 which is orthogonal to q1.
# R[1,2] = q1 . a2 (Inner product)
# Proof: r_ij (i < j) represents the projection of a_j onto the axis q_i.
R[1, 2] <- sum(Q[, 1] * A[, 2])

# v2 = a2 - (q1 . a2) * q1 (Orthogonalization)
# Proof: Subtracting the projection ensures v2 is perpendicular to q1.
v2 <- A[, 2] - R[1, 2] * Q[, 1]

# R[2,2] = ||v2|| (Norm of the remaining orthogonal part)
R[2, 2] <- sqrt(sum(v2^2))

# q2 = v2 / ||v2|| (Normalization)
Q[, 2] <- v2 / R[2, 2]


# --- STEP 3: Process Column 3 ---
# Objective: Find q3 which is orthogonal to both q1 and q2.
# Proof: a3 = r13*q1 + r23*q2 + r33*q3
# Calculate projections of a3 onto existing orthonormal basis {q1, q2}
R[1, 3] <- sum(Q[, 1] * A[, 3])
R[2, 3] <- sum(Q[, 2] * A[, 3])

# v3 = a3 - r13*q1 - r23*q2 (Successive Orthogonalization)
# Proof: v3 is now orthogonal to the subspace spanned by {q1, q2}.
v3 <- A[, 3] - R[1, 3] * Q[, 1] - R[2, 3] * Q[, 2]

# R[3,3] = ||v3|| (Norm of the last orthogonal component)
R[3, 3] <- sqrt(sum(v3^2))

# q3 = v3 / ||v3|| (Final basis vector)
Q[, 3] <- v3 / R[3, 3]


# --- Results and Verification ---
cat("--- Matrix Q (Orthonormal) ---\n")
# Q consists of mutually orthogonal unit vectors.
print(Q)

cat("\n--- Matrix R (Upper Triangular) ---\n")
# R is upper triangular because a_i only depends on q1...q_i.
print(R)

cat("\n--- Verification: Does Q %*% R == A? ---\n")
# Reconstruction: A = QR must hold true.
print(all.equal(Q %*% R, A))

cat("\n--- Orthogonality Check: t(Q) %*% Q (Should be Identity) ---\n")
# Proof: For an orthogonal matrix Q, Q^T * Q = I.
print(round(t(Q) %*% Q, 10))




