# Standard Normal PDF function
f_std_norm <- function(u) {
  return(1/sqrt(2*pi) * exp(-u^2/2))
}

# Example 5.4: Using Indicator Function for Standard Normal
mc_indicator_norm <- function(x, n = 10000) {
  # Generate u in (0, 1) to match the logic of Ex 5.4
  u <- runif(n, 0, 1)
  # Indicator function is 1 if u <= x, else 0
  estimates <- (u <= x) * f_std_norm(u)
  return(mean(estimates))
}

# Example 5.3: Using Variable Transformation (y = t/x) for Standard Normal
mc_transform_norm <- function(x, n = 10000) {
  # Generate u in (0, 1)
  u <- runif(n, 0, 1)
  # Transformation: t = x * u, dt = x * du
  estimates <- x * f_std_norm(x * u)
  return(mean(estimates))
}

