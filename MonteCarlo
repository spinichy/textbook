              -16, -43, 98), nrow = 3, byrow = TRUE)

# 2. Custom function for LDL Decomposition
custom_ldl <- function(A) {
  n <- nrow(A)
  L <- diag(n)        # Initialize L as an Identity Matrix (Diagonal elements = 1)
  D <- rep(0, n)      # Initialize D as a vector to store diagonal elements
  
  for (j in 1:n) {
    # Calculate D[j]
    # D[j] = A[j,j] - sum_{k=1}^{j-1} L[j,k]^2 * D[k]
    if (j == 1) {
      D[j] <- A[j, j]
    } else {
      sum_D <- sum((L[j, 1:(j-1)]^2) * D[1:(j-1)])
      D[j] <- A[j, j] - sum_D
    }
    
    # Calculate L[i,j] for i > j
    # L[i,j] = (1 / D[j]) * (A[i,j] - sum_{k=1}^{j-1} L[i,k] * L[j,k] * D[k])
    if (j < n) {
      for (i in (j + 1):n) {
        if (j == 1) {
          L[i, j] <- A[i, j] / D[j]
        } else {
          sum_L <- sum(L[i, 1:(j-1)] * L[j, 1:(j-1)] * D[1:(j-1)])
          L[i, j] <- (A[i, j] - sum_L) / D[j]
        }
      }
    }
  }
  
  return(list(L = L, D = diag(D)))
}

