sd_scenarios <- c(0.05, 0.5, 2, 16)

# Log density kernel for the Student-t distribution (up to a constant)
log_target_kernel <- function(x, df) {
  return(-((df + 1) / 2) * log(1 + (x^2) / df))
}

# Setup plotting canvas grid: 4 scenarios (rows) x 3 diagnostic types (columns)
par(mfrow = c(4, 3), mar = c(4, 4, 2, 1))

# -----------------------------------------------------------------
# 2. Loop Through Each Proposal SD Scenario
# -----------------------------------------------------------------
for (s in 1:length(sd_scenarios)) {
  current_sd <- sd_scenarios[s]
  t_samples <- numeric(N)
  t_samples[1] <- 0 # Initialize at the center mode
  
  accepted_count <- 0
  
  # Random Walk Metropolis Sampling Loop
  for (t in 1:(N - 1)) {
    current_x <- t_samples[t]
    proposed_y <- rnorm(1, mean = current_x, sd = current_sd)
    
    log_alpha <- log_target_kernel(proposed_y, nu) - log_target_kernel(current_x, nu)
    
    if (log(runif(1)) < log_alpha) {
      t_samples[t + 1] <- proposed_y
      if (t > burn_in) accepted_count <- accepted_count + 1
    } else {
      t_samples[t + 1] <- current_x
    }
  }
  
  # Extract stable post-burn-in chain
  valid_chain <- t_samples[(burn_in + 1):N]
  acceptance_rate <- accepted_count / total_valid_N
  
  # -----------------------------------------------------------------
  # 3. Compute Monte Carlo Error via Batch Means Method (K = 20)
  # -----------------------------------------------------------------
  K <- 20
  v <- total_valid_N / K
  batch_means <- numeric(K)
  
  for (j in 1:K) {
    batch_start <- (j - 1) * v + 1
    batch_end   <- j * v
    batch_means[j] <- mean(valid_chain[batch_start:batch_end])
  }
  
  grand_mean <- mean(valid_chain)
  mc_variance <- sum((batch_means - grand_mean)^2) / (K * (K - 1))
  mc_error    <- sqrt(mc_variance)
  
  # -----------------------------------------------------------------
  # 4. Generate Graphical Panels for Current Scenario
  # -----------------------------------------------------------------
  # Panel 1: Trace Plot with Scenario Metadata Labels
  plot(valid_chain, type = "l", col = "darkred", 
