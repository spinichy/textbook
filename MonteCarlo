n <- nrow(law)
B <- 2000 # Number of outer bootstrap replications
set.seed(123)

# 2. Initialize vectors to store results
# To store theta_hat* from each bootstrap sample
boot_estimates <- numeric(B) 
# To store the jackknife standard error calculated WITHIN each bootstrap sample
boot_jack_se   <- numeric(B) 

# 3. Outer Loop: Bootstrap Resampling
for(b in 1:B) {
  # Generate a bootstrap sample via resampling with replacement
  boot_idx    <- sample(1:n, size = n, replace = TRUE)
  boot_sample <- law[boot_idx, ]
  
  # Calculate the bootstrap replication of theta (theta_hat*)
  boot_estimates[b] <- cor(boot_sample$LSAT, boot_sample$GPA)
  
  # ----------------------------------------------------------------------------
  # Inner Loop: Jackknife applied to the CURRENT bootstrap sample
  # ----------------------------------------------------------------------------
  theta_jack <- numeric(n)
  
  for(i in 1:n) {
    # Omit the i-th observation of the current bootstrap sample
    jack_subsample <- boot_sample[-i, ]
    
    # If the subsample has zero variance due to ties in bootstrap, handle the NaNs
    if(sd(jack_subsample$LSAT) == 0 || sd(jack_subsample$GPA) == 0) {
      theta_jack[i] <- boot_estimates[b]
    } else {
      theta_jack[i] <- cor(jack_subsample$LSAT, jack_subsample$GPA)
    }
  }
  
  # Calculate Jackknife Standard Error for the b-th bootstrap replication
  theta_bar_jack  <- mean(theta_jack)
  boot_jack_se[b] <- sqrt(((n - 1) / n) * sum((theta_jack - theta_bar_jack)^2))
  # ----------------------------------------------------------------------------
}

