# Buffon's Needle Monte Carlo Simulation
set.seed(123)

# Function to estimate Pi based on the number of iterations
buffon_sim <- function(n) {
  # L: length of the needle, D: distance between lines
  L <- 1
  D <- 1
  
  # Generate random center positions of the needle (0 to D/2)
  # 'd' is the distance from the needle's center to the nearest line
  d <- runif(n, min = 0, max = D/2)
  
  # Generate random angles (0 to pi/2)
  theta <- runif(n, min = 0, max = pi/2)
  
  # Condition for the needle crossing a line: d <= (L/2) * sin(theta)
  hits <- sum(d <= (L/2) * sin(theta))
  
  # Estimate probability (P)
  p_hat <- hits / n
  
  # Estimate Pi: Pi = (2 * L) / (P * D)
  # Avoid division by zero if hits is 0
  pi_hat <- if(hits > 0) (2 * L) / (p_hat * D) else NA
  
  return(pi_hat)
}

# Iteration counts as requested
iterations <- c(10, 50, 100, 1000, 5000)

# Run simulations and store results
results <- data.frame(
  Iterations = iterations,
  Estimated_Pi = sapply(iterations, buffon_sim)
)
# Display results
print(results)

# Optional: Plotting the convergence
plot(results$Iterations, results$Estimated_Pi, type = "b", pch = 19, col = "blue",
     main = "Convergence of Pi Estimation",
     xlab = "Number of Iterations", ylab = "Estimated Pi")
abline(h = pi, col = "red", lty = 2) # True value of Pi




