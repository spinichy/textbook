# 1. Setup Simulation Environment
set.seed(4321)        # Set seed for reproducibility
B <- 10000            # Number of Monte Carlo replications
n <- 30               # Sample size

# Function to calculate the estimated Gini ratio (G_hat) using order statistics
calc_gini_hat <- function(x) {
  n_len <- length(x)
  x_sorted <- sort(x)
  x_bar <- mean(x)
  
  # Avoid division by zero if all values are 0
  if (x_bar == 0) return(0)
  
  # Calculate the numerator sum: sum_{i=1}^n (2i - n - 1) * x_(i)
  i_vec <- 1:n_len
  weight_vec <- 2 * i_vec - n_len - 1
  num_sum <- sum(weight_vec * x_sorted)
  
  # G_hat formula
  gini_hat <- num_sum / (n_len^2 * x_bar)
  return(gini_hat)
}

# Initialize vectors to store simulated G_hat values
gini_lognorm <- numeric(B)
gini_unif    <- numeric(B)
gini_bern    <- numeric(B)

# 2. Perform Monte Carlo Simulation
for (b in 1:B) {
  # (i) Standard Log-normal distribution
  sample_lognorm <- rlnorm(n, meanlog = 0, sdlog = 1)
  gini_lognorm[b] <- calc_gini_hat(sample_lognorm)
  
  # (ii) Uniform distribution over (0, 1)
