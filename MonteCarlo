sample_sizes <- c(20, 50)     # Evaluating small and medium sample sizes
methods <- c("pearson", "spearman", "kendall")

# Matrix to store empirical power values
power_results <- matrix(NA, nrow=length(methods), ncol=length(sample_sizes),
                        dimnames=list(methods, paste0("n=", sample_sizes)))

# Mean vector and Covariance matrix structure for bivariate normal
mu_vec <- c(0, 0)

# Run the simulation loop
for(j in 1:length(sample_sizes)){
  n <- sample_sizes[j]
  
  # Define covariance matrix based on true_rho
  sigma_mat <- matrix(c(1, true_rho, true_rho, 1), nrow=2)
  
  # Vectors to store p-values for each replication
  p_pearson  <- numeric(B)
  p_spearman <- numeric(B)
  p_kendall  <- numeric(B)
  
  for(b in 1:B){
    # Generate bivariate normal data
    data_mat <- mvrnorm(n=n, mu=mu_vec, Sigma=sigma_mat)
    x <- data_mat[, 1]
    y <- data_mat[, 2]
    
    # Perform correlation tests and extract p-values
    # Exact paths or asymptotic approximations are handled internally by cor.test
    p_pearson[b]  <- cor.test(x, y, method="pearson")$p.value
    p_spearman[b] <- suppressWarnings(cor.test(x, y, method="spearman")$p.value)
    p_kendall[b]  <- suppressWarnings(cor.test(x, y, method="kendall")$p.value)
  }
  
  # Calculate empirical power (proportion of p-values < alpha)
  power_results["pearson", j]  <- mean(p_pearson < alpha)
  power_results["spearman", j] <- mean(p_spearman < alpha)
  power_results["kendall", j]  <- mean(p_kendall < alpha)
}

# Display the final empirical power results
print(round(power_results, 4))




