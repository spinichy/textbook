# 2. Stratified Sampling (SS)
# ---------------------------------------------------------
# Divide [0, 1] into k strata
k <- 10 
m_j <- m / k  # Number of samples per stratum (m_j is a constant)

# Initialize vector to store results from each stratum
strata_estimates <- numeric(k)
strata_variances <- numeric(k)

for (j in 1:k) {
  # Define stratum boundaries [a, b]
  a <- (j - 1) / k
  b <- j / k
  
  # Sample from U(a, b)
  u_j <- runif(m_j, min = a, max = b)
  
  # Stratum estimate: (b-a) * mean(h(x))
  # Since (b-a) = 1/k and we sum them later:
  strata_estimates[j] <- mean(h(u_j)) * (1/k)
  strata_variances[j] <- var(h(u_j) * (1/k)) / m_j
}

# Final combined estimate and standard error
est_ss <- sum(strata_estimates)
se_ss <- sqrt(sum(strata_variances))

# ---------------------------------------------------------
# 3. Comparison of Results
# ---------------------------------------------------------
results <- data.frame(
  Method = c("Simple MC", "Stratified Sampling"),
  Estimate = c(est_smc, est_ss),
  StdError = c(se_smc, se_ss)
)

print(results)

# Efficiency comparison
cat("\nVariance Reduction Ratio (SMC Var / SS Var):", (se_smc^2) / (se_ss^2), "\n")


