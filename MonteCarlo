  q, 0, 0, p, 0,  # State 2: reset to 0 or move to 3
  q, 0, 0, 0, p,  # State 3: reset to 0 or move to 4 (Target)
  0, 0, 0, 0, 1   # State 4: Absorbing state
), nrow = 5, byrow = TRUE)

# 2. Extract the sub-matrix Q (Non-absorbing states)
# We take rows and columns 1 to 4
Q <- P[1:4, 1:4]

# 3. Calculate the Fundamental Matrix N = (I - Q)^-1
# I is the Identity matrix
I <- diag(4)
N <- solve(I - Q)

# 4. Expected number of steps to reach state 4 starting from state 0
# Sum the first row of N
expected_steps <- sum(N[1, ])

# Output result
print("Fundamental Matrix N:")
print(N)
cat("\nTheoretical Expected Attempts:", expected_steps, "\n")



