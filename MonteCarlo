# Function to generate Beta(a, b) samples using Acceptance-Rejection Method
# We use Uniform(0, 1) as the proposal distribution g(x) = 1
rbeta_rejection <- function(n, a, b) {
  samples <- numeric(n)
  count <- 0
  
  # 1. Find the constant M (maximum of the Beta PDF)
  # The mode of Beta(a, b) is (a-1)/(a+b-2) for a, b > 1
  mode_x <- (a - 1) / (a + b - 2)
  M <- dbeta(mode_x, a, b)
  
  while (count < n) {
    # Step 1: Generate Y from proposal distribution g(y) = Uniform(0, 1)
    Y <- runif(1)
    
    # Step 2: Generate U from Uniform(0, 1)
    U <- runif(1)
    
    # Step 3: Accept-Reject test
    # Accept if U <= f(Y) / (M * g(Y))
    if (U <= dbeta(Y, a, b) / M) {
      count <- count + 1
      samples[count] <- Y
    }
  }
  return(samples)
}

