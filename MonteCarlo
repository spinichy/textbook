# -------------------------------------------------------------------------
# Monte Carlo Simulation Setup
# -------------------------------------------------------------------------
set.seed(123)            # Set seed for reproducibility
B <- 10000               # Number of Monte Carlo replications
n <- 100                 # Sample size per replication (large sample approximation)

# Define true parameters (Gini coefficient is independent of mu)
true_mu <- 0
true_sigma <- 1

# Calculate the true Gini coefficient (True Gamma)
true_gamma <- 2 * pnorm(true_sigma / sqrt(2)) - 1

# Initialize a vector to store coverage results
covered <- numeric(B)

# -------------------------------------------------------------------------
# Simulation Loop
# -------------------------------------------------------------------------
for(b in 1:B) {
  # 1. Generate data from a Lognormal distribution
  x <- rlnorm(n, meanlog = true_mu, sdlog = true_sigma)
  
  # 2. Log-transform data and estimate sigma
  y <- log(x)
  est_sigma <- sd(y) 
  
  # 3. Estimate the Gini coefficient (Gamma hat)
  est_gamma <- 2 * pnorm(est_sigma / sqrt(2)) - 1
  
  # 4. Calculate Standard Error (SE) using the Delta Method
  # Note: dnorm() acts as the standard normal PDF, phi(.)
  se_gamma <- (est_sigma / sqrt(n)) * dnorm(est_sigma / sqrt(2))
  
  # 5. Derive the approximate 95% Confidence Interval (Wald-type CI)
  lower_ci <- est_gamma - 1.96 * se_gamma
  upper_ci <- est_gamma + 1.96 * se_gamma
  
  # 6. Check if the true Gamma falls within the computed CI (True=1, False=0)
  covered[b] <- (true_gamma >= lower_ci) & (true_gamma <= upper_ci)
}

# -------------------------------------------------------------------------
# Output Results
# -------------------------------------------------------------------------
# Calculate and print the empirical coverage probability
coverage_prob <- mean(covered)
cat("True Gini Coefficient (True Gamma):", true_gamma, "\n")
cat("Estimated Coverage Probability of 95% CI via Monte Carlo:", coverage_prob, "\n")



