# Metropolis algorithm for standard Laplace distribution
# Target density: f(x) = 0.5 * exp(-abs(x))
# Proposal distribution: Uniform(-w, w)

set.seed(42) # Set seed for reproducibility

metropolis_uniform <- function(n_iterations, w) {
  # Initialize storage for samples
  samples <- numeric(n_iterations)
  current_x <- 0
  accept_count <- 0
  
  for (i in 1:n_iterations) {
    # Generate candidate from Uniform(current_x - w, current_x + w)
    candidate <- runif(1, min = current_x - w, max = current_x + w)
    
    # Calculate acceptance ratio
    # log(f(candidate) / f(current)) = abs(current) - abs(candidate)
    log_ratio <- abs(current_x) - abs(candidate)
    
    # Accept or reject candidate
    if (log(runif(1)) < log_ratio) {
      current_x <- candidate
      accept_count <- accept_count + 1
    }
    samples[i] <- current_x
  }
  
  return(list(samples = samples, accept_rate = accept_count / n_iterations))
}

