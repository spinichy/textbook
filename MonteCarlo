# Target: Rayleigh distribution with sigma = 2
# PDF: f(x) = (x / sigma^2) * exp(-x^2 / (2 * sigma^2))
target_pdf <- function(x, sigma = 2) {
  if (x < 0) return(0)
  return((x / sigma^2) * exp(-x^2 / (2 * sigma^2)))
}

# Metropolis-Hastings Sampler
mh_sampler <- function(n_iter, df_proposal, target_sigma = 2) {
  samples <- numeric(n_iter)
  current_x <- 2 # Initial value
  
  for (i in 1:n_iter) {
    # Proposal: Chi-squared distribution
    proposal_x <- rchisq(1, df = df_proposal)
    
    # M-H ratio: (target(prop) * prop(curr|prop)) / (target(curr) * prop(prop|curr))
    # Note: Using dchisq as symmetric or specific transition logic here
    ratio <- (target_pdf(proposal_x, target_sigma) * dchisq(current_x, df = df_proposal)) /
      (target_pdf(current_x, target_sigma) * dchisq(proposal_x, df = df_proposal))
    
    alpha <- min(1, ratio)
    
    if (runif(1) < alpha) {
      current_x <- proposal_x
    }
    samples[i] <- current_x
  }
  return(samples)
}

