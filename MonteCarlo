# Monte Carlo Simulation for Q2
# Condition: Stop when a girl is born or total children reach 4.

set.seed(123) # For reproducibility
n_sim <- 100000 # Number of iterations
has_girl <- logical(n_sim)

for (i in 1:n_sim) {
  children <- c()
  
  for (j in 1:4) {
    # Generate a child: 0 for Boy, 1 for Girl
    child <- sample(c(0, 1), 1, prob = c(0.5, 0.5))
    children <- c(children, child)
    
    # Stop if the child is a girl
    if (child == 1) {
      break
    }
  }
  
  # Check if there is at least one girl in the family
  has_girl[i] <- any(children == 1)
}

