  # Step B: Generate u from U(0,1)
  u_val <- runif(1)
  
  # Step C: Acceptance Criterion
  if (u_val < f_norm(y_cand) / (c_val * g_laplace(y_cand))) {
    count <- count + 1
    samples[count] <- y_cand
  }
