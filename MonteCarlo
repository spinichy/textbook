# Define a function to compute theta_hat from a given dataframe
# theta_hat = max_eigenvalue / sum(all_eigenvalues)
compute_theta <- function(data) {
  # Compute the maximum likelihood estimate (MLE) of the covariance matrix
  # MLE of covariance matrix divides by n, though using sample covariance (dividing by n-1) 
  # yields identical eigenvalues ratio since the scale factor cancels out.
  cov_matrix <- cov(data) * (nrow(data) - 1) / nrow(data)
  
  # Perform eigenvalue decomposition
