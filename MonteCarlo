# Gibbs sampler for the Random Effects Model
# Model: y_ij = mu + alpha_i + eps_ij
# Target: Posterior of (alpha, mu, sigma_alpha^2, sigma^2)

set.seed(42)

# --- 1. Data Setup (Example) ---
k <- 5   # Number of groups
n <- 10  # Observations per group
# Simulate some data (not needed if you have actual y)
mu_true <- 10
alpha_true <- rnorm(k, 0, 2)
sigma_sq_true <- 1
y <- matrix(rnorm(k * n, mu_true + alpha_true, sqrt(sigma_sq_true)), nrow=k, byrow=TRUE)

# --- 2. Initialize Parameters ---
n_iter <- 10000
mu <- mean(y)
alpha <- rep(0, k)
sigma_alpha_sq <- 1
sigma_sq <- 1

# Storage
res_mu <- numeric(n_iter)
res_alpha <- matrix(0, nrow=n_iter, ncol=k)

# --- 3. Gibbs Sampling Loop ---
for (i in 1:n_iter) {
  # (b) Update mu | y, alpha, sigma_sq
  # mu ~ N(mean(y_ij - alpha_i), sigma^2 / (k*n))
  y_bar_dot_dot <- mean(y - alpha) # simplified mean
  mu <- rnorm(1, mean = mean(y - alpha), sd = sqrt(sigma_sq / (k * n)))
  
  # (a) Update alpha_i | y, mu, sigma_alpha_sq, sigma_sq
  # alpha_i ~ N( (n*sigma_alpha^2 * mean(y_i - mu)) / (n*sigma_alpha^2 + sigma^2), ... )
  for (j in 1:k) {
    y_bar_i <- mean(y[j, ] - mu)
    var_alpha <- (sigma_sq * sigma_alpha_sq) / (n * sigma_alpha_sq + sigma_sq)
    mean_alpha <- (n * sigma_alpha_sq * y_bar_i) / (n * sigma_alpha_sq + sigma_sq)
    alpha[j] <- rnorm(1, mean = mean_alpha, sd = sqrt(var_alpha))
  }
  
  # (c) Update sigma_alpha_sq | alpha
  # sigma_alpha_sq ~ IG(k/2, sum(alpha^2)/2)
  sigma_alpha_sq <- 1 / rgamma(1, shape = k/2, rate = sum(alpha^2)/2)
  
  # (d) Update sigma_sq | y, mu, alpha
  # sigma_sq ~ IG(kn/2, sum((y - mu - alpha)^2)/2)
  sse <- sum((y - mu - alpha)^2)
  sigma_sq <- 1 / rgamma(1, shape = (k * n) / 2, rate = sse / 2)
  
  # Store
  res_mu[i] <- mu
  res_alpha[i, ] <- alpha
}

