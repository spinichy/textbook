  # Calculate t-statistic using the null hypothesis assumption (mu_0 = 0)
  sample_mean <- mean(sample_data)
  sample_sd <- sd(sample_data)
  t_statistics[j] <- (sample_mean - mu_0) / (sample_sd / sqrt(n))
  
  # Check if H0 is rejected (One-tailed test)
  if (t_statistics[j] > critical_value) {
    rejection_indicator[j] <- 1
  }
}

# 3. Calculate Empirical vs Theoretical Power
empirical_power <- mean(rejection_indicator)

# Theoretical power using the CDF of the Non-central t-distribution
theoretical_power <- 1 - pt(critical_value, df = df, ncp = delta)

cat("----------------------------------------\n")
cat("Empirical Power (Monte Carlo) :", empirical_power, "\n")
cat("Theoretical Power (Non-central t):", theoretical_power, "\n")
