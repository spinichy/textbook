    count <- count + 1
    # Simulate one jump (1 = success, 0 = failure)
    is_success <- rbinom(1, 1, p_success)
    
    if (is_success == 1) {
      consecutive <- consecutive + 1
    } else {
      consecutive <- 0  # Reset streak upon failure
    }
  }
  total_attempts_needed[i] <- count
}

