# Parameters
L <- 1            # Needle length
d <- 1            # Distance between lines
N <- 10000        # Tosses per experiment
experiments <- 5000 # Number of simulations to see the distribution of Pi

# Set seed for reproducibility
set.seed(123)

# Function to estimate one Pi from N tosses
estimate_pi <- function(n_tosses, length_l, dist_d) {
  x <- runif(n_tosses, min = 0, max = dist_d/2)
  theta <- runif(n_tosses, min = 0, max = pi/2)
  hits <- sum(x <= (length_l/2) * sin(theta))
  p_hat <- hits / n_tosses
  pi_hat <- (2 * length_l) / (dist_d * p_hat)
  return(pi_hat)
}

# Run multiple experiments
pi_results <- replicate(experiments, estimate_pi(N, L, d))

# 1. Empirical (Simulated) Standard Error
simulated_se <- sd(pi_results)

# 2. Theoretical Standard Error (using Delta Method)
# Formula: pi * sqrt((pi - 2) / (2 * N))
theoretical_se <- pi * sqrt((pi - 2) / (2 * N))

# Output Results
cat("Average of Estimated Pi:", mean(pi_results), "\n")
cat("Simulated Standard Error:", simulated_se, "\n")
cat("Theoretical Standard Error:", theoretical_se, "\n")

# Visualization
hist(pi_results, breaks = 50, prob = TRUE, 
     main = "Buffon's Needle: Distribution of Estimated Pi",
     xlab = "Estimated Pi")
curve(dnorm(x, mean = pi, sd = theoretical_se), 
      add = TRUE, col = "blue", lwd = 2)
