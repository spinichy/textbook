# Function to check if a sequence has a streak of 3 or more
has_streak <- function(flips, n) {
  # rle (Run Length Encoding) counts consecutive values
  runs <- rle(flips)
  # Check if any run length is greater than or equal to n
  return(any(runs$lengths >= n))
}

