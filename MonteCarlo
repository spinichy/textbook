# -------------------------------------------------------------------------
# Power Comparison: Skewness vs. Shapiro-Wilk vs. Kolmogorov-Smirnov (KS)
# -------------------------------------------------------------------------

# 1. Define Skewness Function
calc_skewness <- function(x) {
  n <- length(x)
  mean_x <- mean(x)
  m3 <- sum((x - mean_x)^3) / n
  m2 <- sum((x - mean_x)^2) / n
  return(m3 / (m2^(1.5)))
}

# 2. Setup Simulation Parameters
set.seed(42)
n <- 30
alpha <- 0.1
m <- 2000

epsilon_vector <- seq(0, 1, by = 0.1)

# Arrays to store empirical power for each test
power_sk <- numeric(length(epsilon_vector))
power_sw <- numeric(length(epsilon_vector))
power_ks <- numeric(length(epsilon_vector))

# 3. Pre-calculate Empirical Critical Values for Skewness Test (H0: epsilon = 0)
null_skewness <- numeric(m)
for (j in 1:m) {
  null_sample <- rnorm(n, mean = 0, sd = 1)
  null_skewness[j] <- calc_skewness(null_sample)
}
lower_crit_sk <- quantile(null_skewness, alpha / 2)
upper_crit_sk <- quantile(null_skewness, 1 - alpha / 2)

# 4. Run Main Simulation Loop
for (i in 1:length(epsilon_vector)) {
  eps <- epsilon_vector[i]
  
  reject_sk <- 0
  reject_sw <- 0
  reject_ks <- 0
  
  for (j in 1:m) {
    # Generate Normal Mixture Sample: (1 - eps)*N(0,1) + eps*N(0,100)
    components <- rbinom(n, size = 1, prob = eps)
    sample_data <- numeric(n)
    for (k in 1:n) {
      if (components[k] == 0) {
        sample_data[k] <- rnorm(1, mean = 0, sd = 1)
      } else {
        sample_data[k] <- rnorm(1, mean = 0, sd = 10) # sd = sqrt(100)
      }
    }
    
    # [Test 1] Skewness Test
    sk_val <- calc_skewness(sample_data)
    if (sk_val < lower_crit_sk || sk_val > upper_crit_sk) {
      reject_sk <- reject_sk + 1
    }
    
    # [Test 2] Shapiro-Wilk Test (H0: Data is normally distributed)
    sw_result <- shapiro.test(sample_data)
    if (sw_result$p.value < alpha) {
      reject_sw <- reject_sw + 1
    }
    
    # [Test 3] Kolmogorov-Smirnov Test 
    # Compare with standard normal distribution CDF (pnorm)
    ks_result <- ks.test(sample_data, "pnorm", mean = mean(sample_data), sd = sd(sample_data))
    if (ks_result$p.value < alpha) {
      reject_ks <- reject_ks + 1
    }
  }
  
  # Calculate Empirical Power for each test
  power_sk[i] <- reject_sk / m
  power_sw[i] <- reject_sw / m
  power_ks[i] <- reject_ks / m
}

# 5. Combine Results into a Data Frame
power_comparison <- data.frame(
  Epsilon = epsilon_vector,
  Skewness = power_sk,
  Shapiro_Wilk = power_sw,
  KS_Test = power_ks
)
print(power_comparison)

# 6. Plot the Power Comparison Curves
windows()
plot(
  x = power_comparison$Epsilon, y = power_comparison$Shapiro_Wilk,
  type = "b", pch = 19, col = "blue", lwd = 2,
  xlab = expression(paste("Contamination Rate (", epsilon, ")")),
  ylab = "Empirical Power",
  main = "Power Comparison under Normal Mixture Alternative",
