  # Generate normal random samples under H0 (Standard Normal)
  sample_data <- rnorm(n_val, mean = 0, sd = 1)
  skewness_sim[b] <- calc_skewness(sample_data)
}

# 3. Calculate Empirical Quantiles and Standard Errors via Normal Approximation
empirical_quantiles <- quantile(skewness_sim, probs = quantiles_to_est)

# Asymptotic variance parameters under Large-Sample Theory: sqrt(b1) ~ N(0, 6/n)
asymp_se_dist <- sqrt(6 / n_val) 

# Calculate Standard Error for each estimated quantile using Equation (2.14) logic
# SE = sqrt( (alpha * (1 - alpha)) / (B * [f(q_alpha)]^2) )
quantile_se <- numeric(length(quantiles_to_est))

