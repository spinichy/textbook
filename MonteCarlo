# Parameters
n <- 20    # Number of trials
a <- 2     # Beta distribution parameter
b <- 2     # Beta distribution parameter
n_iter <- 5000

# Storage
x_samples <- numeric(n_iter)
y_samples <- numeric(n_iter)

# Initial value for y
curr_y <- 0.5 

# Gibbs sampling loop
for (i in 1:n_iter) {
  # 1. Sample x from conditional: Binomial(n, y)
  x_samples[i] <- rbinom(1, size = n, prob = curr_y)
  
  # 2. Sample y from conditional: Beta(x+a, n-x+b)
  y_samples[i] <- rbeta(1, shape1 = x_samples[i] + a, shape2 = n - x_samples[i] + b)
  
  # Update current_y for next iteration
  curr_y <- y_samples[i]
}

