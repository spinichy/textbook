estimate_pi <- function(n_tosses, length_l, dist_d) {
  x <- runif(n_tosses, min = 0, max = dist_d/2)
  theta <- runif(n_tosses, min = 0, max = pi/2)
  hits <- sum(x <= (length_l/2) * sin(theta))
