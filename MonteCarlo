# Metropolis algorithm for standard Laplace distribution
# Target density: f(x) = 0.5 * exp(-abs(x))

set.seed(123)

metropolis_laplace <- function(n_iterations, sigma) {
  samples <- numeric(n_iterations)
  current_x <- 0
  accept_count <- 0
  
  for (i in 1:n_iterations) {
    # Random walk: candidate = current + increment(N(0, sigma^2))
    candidate <- current_x + rnorm(1, mean = 0, sd = sigma)
    
    # Acceptance ratio calculation
    # log(f(x')) / log(f(x)) = -abs(x') - (-abs(x))
    log_ratio <- abs(current_x) - abs(candidate)
    
    if (log(runif(1)) < log_ratio) {
      current_x <- candidate
      accept_count <- accept_count + 1
    }
    samples[i] <- current_x
  }
  
  return(list(samples = samples, accept_rate = accept_count / n_iterations))
}

