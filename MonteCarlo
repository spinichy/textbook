# (c) Posterior probability changes for different sigma^2
sigma_sq_list <- c(1, 5, 10, 100)
y_fixed <- 1
results <- data.frame()

for(s2 in sigma_sq_list) {
  s <- sqrt(s2)
  # Likelihoods at y = 1
  lik2 <- dnorm(y_fixed, mean = 2, sd = s)
  lik10 <- dnorm(y_fixed, mean = 10, sd = s)
  
  # Posterior P(theta=2 | y=1)
  post2 <- (lik2 * 0.5) / (lik2 * 0.5 + lik10 * 0.5)
  results <- rbind(results, data.frame(sigma_sq = s2, post_theta2 = post2))
}

# Visualization
barplot(results$post_theta2, names.arg = results$sigma_sq, 
        ylim = c(0, 1), col = "orange",
        main = "Posterior P(theta=2 | y=1) by sigma^2",
        xlab = "Variance (sigma^2)", ylab = "Probability")


