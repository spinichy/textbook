# 1. Acceptance-Rejection Method for Beta(a, b)
# We use a Uniform(0, 1) as the proposal distribution.
# The constant M must satisfy f(x) <= M * g(x).
beta_ar <- function(n, a, b) {
  samples <- numeric(n)
  count <- 0
  
  # Find the maximum value of the Beta density to set M
  # For a, b > 1, the mode is (a-1)/(a+b-2)
  if (a > 1 && b > 1) {
    mode_val <- (a - 1) / (a + b - 2)
    M <- dbeta(mode_val, a, b)
  } else {
    M <- 2 # Default fallback for simplicity
  }
  
  while (count < n) {
    U <- runif(1) # Proposal distribution sample (Uniform)
    V <- runif(1) # Acceptance decision variable
    
    # Accept if V <= f(U) / M
    if (V <= dbeta(U, a, b) / M) {
      count <- count + 1
      samples[count] <- U
    }
  }
  return(samples)
}

