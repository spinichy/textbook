# (a) Generate 1,000 steps of a Markov Chain starting from position 1
n_steps <- 10000
path <- numeric(n_steps)
current_state <- 1  # Starting at position 1
path[1] <- current_state

for (i in 2:n_steps) {
  # Select next state based on the probabilities in the current state's row
  current_state <- sample(1:5, size = 1, prob = P[current_state, ])
  path[i] <- current_state
}


# (b) Calculate relative frequencies and estimate stationary distribution w
relative_frequencies <- table(path) / n_steps
w_estimated <- as.numeric(relative_frequencies)

cat("(b) Relative Frequencies (Estimated w):\n")
print(w_estimated)

# (c) Verify if the estimated distribution is stationary using w %*% P
verification <- w_estimated %*% P

cat("\n(c) Verification (w %*% P):\n")
print(verification)

# Comparison
cat("\nDifference between w and w%*%P:\n")
print(w_estimated - verification)


