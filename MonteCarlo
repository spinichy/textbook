# 2. M-H Sampler with Gamma Proposal
# Proposal: Y ~ Gamma(shape = Xt, rate = 1)
run_adaptive_mh <- function(n_iter = 5000, start_x) {
  samples <- numeric(n_iter)
  current_x <- start_x
  
  for (i in 1:n_iter) {
    # Generate proposal from Gamma(shape = current_x, rate = 1)
    proposal_x <- rgamma(1, shape = current_x, rate = 1)
    
    # Calculate M-H ratio for non-symmetric proposal:
    # ratio = [target(y) * q(x|y)] / [target(x) * q(y|x)]
    num <- target_pdf(proposal_x) * dgamma(current_x, shape = proposal_x, rate = 1)
    den <- target_pdf(current_x) * dgamma(proposal_x, shape = current_x, rate = 1)
    
    alpha <- min(1, num / den)
    
    # Accept or Reject
    if (runif(1) < alpha) {
      current_x <- proposal_x
    }
    samples[i] <- current_x
  }
  return(samples)
}

