# Function to generate a single Metropolis-Hastings chain
normal.chain <- function(init_val, n_iter, proposal_sd) {
  chain <- numeric(n_iter)
  chain[1] <- init_val
  
  for (t in 2:n_iter) {
    current <- chain[t - 1]
    
    # Propose a new candidate from the normal proposal distribution
    proposal <- rnorm(1, mean = current, sd = proposal_sd)
    
    # Evaluate log-target densities for standard normal distribution N(0, 1)
    log_target_current  <- dnorm(current, mean = 0, sd = 1, log = TRUE)
    log_target_proposal <- dnorm(proposal, mean = 0, sd = 1, log = TRUE)
    
    # Calculate the log acceptance probability ratio
    log_alpha <- log_target_proposal - log_target_current
    
    # Accept or reject the proposed value
    if (log(runif(1)) < log_alpha) {
      chain[t] <- proposal
    } else {
      chain[t] <- current
    }
  }
  return(chain)
}

# Function to calculate Gelman-Rubin diagnostic (Potential Scale Reduction Factor)
gelman.rubin.base <- function(chains_matrix) {
  N <- nrow(chains_matrix) # Number of iterations
  M <- ncol(chains_matrix) # Number of chains
  
  # 1. Compute empirical means for each individual chain
  chain_means <- colMeans(chains_matrix)
  
  # 2. Compute the grand mean across all simulated samples
  overall_mean <- mean(chain_means)
  
  # 3. Calculate between-chain variance (B) based on ANOVA principles
  B <- (N / (M - 1)) * sum((chain_means - overall_mean)^2)
  
  # 4. Calculate within-chain variance (W) by averaging sample variances
  chain_vars <- apply(chains_matrix, 2, var)
  W <- mean(chain_vars)
  
  # 5. Estimate the marginal posterior variance (weighted average of W and B)
  var_plus <- ((N - 1) / N) * W + (1 / N) * B
  
  # 6. Compute the final R_hat shrinkage factor
  R_hat <- sqrt(var_plus / W)
  
  return(R_hat)
}

