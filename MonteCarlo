    jack_estimates_boot[j] <- cor(boot_sample[-j, "LSAT"], boot_sample[-j, "GPA"])
  }
  se_boot_star <- sqrt(((n - 1) / n) * sum((jack_estimates_boot - mean(jack_estimates_boot))^2))
  
  # Avoid division by zero if se_boot_star happens to be 0
