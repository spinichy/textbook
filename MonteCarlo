# Target function: Standard Normal PDF
g <- function(t) dnorm(t)

# Settings
n <- 10000
set.seed(123)
alpha <- 0.05
z_critical <- qnorm(1 - alpha/2) # 1.96 for 95% CI

# 1. Define 10 x values between 0.1 and 2.5
x_values <- seq(0.1, 2.5, length.out = 10)

# 2. Function to estimate Phi(x) with Confidence Interval
estimate_phi_with_ci <- function(x, n_samples) {
  if (x == 0) return(data.frame(est = 0.5, lower = 0.5, upper = 0.5))
  
  # Generate samples in [0, x]
  t_samples <- runif(n_samples, 0, x)
  y_values <- g(t_samples)
  
  # Sample mean of g(t)
  mean_g <- mean(y_values)
  
  # Area estimate: 0.5 + x * E[g(T)]
  est_val <- 0.5 + (x * mean_g)
  
  # Standard Error of the estimator
  # Var(Est) = x^2 * Var(g(T)) / n
  se <- x * (sd(y_values) / sqrt(n_samples))
  
  # 95% Confidence Interval
  lower_ci <- est_val - (z_critical * se)
  upper_ci <- est_val + (z_critical * se)
  
  return(data.frame(x = x, est = est_val, lower = lower_ci, upper = upper_ci))
}

# 3. Perform estimation for each x value
results_list <- lapply(x_values, function(x) {
  true_val <- pnorm(x)
  mc_res <- estimate_phi_with_ci(x, n)
  
  data.frame(
    x = x,
    Theoretical_CDF = true_val,
    MC_Estimate = mc_res$est,
    Lower_95_CI = mc_res$lower,
    Upper_95_CI = mc_res$upper
  )
})

