# -------------------------------------------------------------------------
# Function: Asymptotic Skewness Test for Normality
# -------------------------------------------------------------------------
asymptotic_skewness_test <- function(x, alpha = 0.05) {
  n <- length(x)
  
  # Calculate sample moments
  mean_x <- mean(x)
  m2 <- mean((x - mean_x)^2)  # 2nd central moment (sample variance)
  m3 <- mean((x - mean_x)^3)  # 3rd central moment
  
  # Calculate sample skewness (g1)
  skewness_hat <- m3 / (m2^(1.5))
  
  # Asymptotic variance under the null hypothesis (H0: Skewness = 0)
  asymptotic_var <- 6 / n
  se_skewness <- sqrt(asymptotic_var)
  
  # Calculate Z-statistic and two-sided p-value
  z_stat <- skewness_hat / se_skewness
  p_value <- 2 * pnorm(abs(z_stat), lower.tail = FALSE)
  
  # Return results as a structured list
  result <- list(
    sample_size = n,
    skewness = skewness_hat,
    se = se_skewness,
    z_statistic = z_stat,
    p_value = p_value,
    decision = ifelse(p_value < alpha, "Reject H0 (Non-normal)", "Fail to Reject H0 (Normal)")
  )
  
  return(result)
}

