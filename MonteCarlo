# 2. Define Log-Posterior Kernel
log_posterior_kernel <- function(beta, obs) {
  if (beta <= 0 || beta >= 0.5) return(-Inf)
  return((obs[4] + obs[5]) * log(beta) + obs[2] * log(1 - beta) + obs[3] * log(1 - 2 * beta))
}

# 3. Execute Random Walk Metropolis Sampling Loop
beta_samples <- numeric(N)
beta_samples[1] <- 0.25 # Initial value at the midpoint

for (t in 1:(N - 1)) {
  current_beta <- beta_samples[t]
  proposed_y <- current_beta + runif(1, min = -0.25, max = 0.25)
  log_alpha <- log_posterior_kernel(proposed_y, x_data) - log_posterior_kernel(current_beta, x_data)
  
  if (log(runif(1)) < log_alpha) {
    beta_samples[t + 1] <- proposed_y
  } else {
    beta_samples[t + 1] <- current_beta
  }
}

# Extract stable samples after discarding the burn-in period
