# 2. Custom function for Cholesky Decomposition (Lower Triangular)
custom_cholesky <- function(A) {
  n <- nrow(A)
  L <- matrix(0, n, n) # Initialize result matrix with zeros
  
  for (i in 1:n) {
    for (j in 1:i) {
      sum_val <- 0
      
      if (i == j) {
        # Diagonal elements: L[i,i] = sqrt(A[i,i] - sum(L[i,k]^2))
        if (j > 1) {
          sum_val <- sum(L[i, 1:(j-1)]^2)
        }
        L[i, j] <- sqrt(A[i, j] - sum_val)
      } else {
        # Off-diagonal elements: L[i,j] = (1 / L[j,j]) * (A[i,j] - sum(L[i,k] * L[j,k]))
        if (j > 1) {
          sum_val <- sum(L[i, 1:(j-1)] * L[j, 1:(j-1)])
        }
        L[i, j] <- (A[i, j] - sum_val) / L[j, j]
      }
    }
  }
  return(L)
}

