# 1. Define a square matrix A
A <- matrix(c(4, 1, -2, 2,
              1, 2, 0, 1,
              -2, 0, 3, -2,
              2, 1, -2, 1), nrow = 4, byrow = TRUE)

# 2. Function for Hessenberg Decomposition
hessenberg_decomp <- function(A) {
  n <- nrow(A)
  H <- A
  P_total <- diag(n)
  
  # Iterate to zero out elements below the first subdiagonal
  for (j in 1:(n - 2)) {
    # Extract the vector to be transformed
    x <- H[(j+1):n, j]
    
    # Householder vector calculation
    e1 <- c(1, rep(0, length(x) - 1))
    v <- x + sign(x[1]) * sqrt(sum(x^2)) * e1
    v <- v / sqrt(sum(v^2))
    
    # Householder matrix for this step
    H_sub <- diag(length(x)) - 2 * (v %*% t(v))
    
    # Expand to full size identity-based transformation matrix
    P_j <- diag(n)
    P_j[(j+1):n, (j+1):n] <- H_sub
    
    # Similarity transformation: H = P_j %*% H %*% t(P_j)
    H <- P_j %*% H %*% t(P_j)
    
    # Keep track of the total transformation matrix P
    P_total <- P_total %*% t(P_j)
  }
  
  return(list(H = H, P = P_total))
}

# 3. Execution
result <- hessenberg_decomp(A)
H <- result$H
P <- result$P

# 4. Results Output
cat("--- Original Matrix A ---\n")
print(A)

cat("\n--- Upper Hessenberg Matrix H ---\n")
# Rounding for clear view of zero elements
print(round(H, 10))

cat("\n--- Orthogonal Matrix P ---\n")
print(round(P, 10))

# 5. Verification: A = P %*% H %*% t(P)
reconstructed_A <- P %*% H %*% t(P)
cat("\n--- Verification (P * H * P^T) ---\n")
print(round(reconstructed_A, 10))



