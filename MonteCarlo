# Multiplicative Congruential Generator (MCG)
# Specific case: Park-Miller Generator (Minimum Standard)

create_mcg <- function(seed, n = 10) {
  # 1. Parameters (Park-Miller)
  # M is a Mersenne prime (2^31 - 1)
  # a is a primitive root modulo M
  # c is 0 (This is what makes it 'Multiplicative')
  
  m <- 2^31 - 1
  a <- 48271
  
  # Seed check: In MCG, seed must NOT be 0
  if (seed == 0) {
    stop("In MCG, seed cannot be 0 because it will trap the sequence at 0.")
  }
  
  random_numbers <- numeric(n)
  current_x <- seed
  
  for (i in 1:n) {
    # Formula: X_{n+1} = (a * X_n) mod M
    # Use modulo carefully with large numbers
    current_x <- (a * current_x) %% m
    
    # Scaling to [0, 1) range
    random_numbers[i] <- current_x / m
  }
  
  return(random_numbers)
}

# Example Usage
# Generate 5 random numbers with seed 1
samples <- create_mcg(seed = 1, n = 5)
print(samples)


