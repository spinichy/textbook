# Function to generate a single Poisson random variable
inv_poisson <- function(lambda) {
  u <- runif(1)
  i <- 0
  p <- exp(-lambda)
  f <- p
  
  # Accumulate probabilities until they exceed u
  while (u > f) {
    i <- i + 1
    p <- p * lambda / i # Recurrence relation: P(X=i) = P(X=i-1) * lambda / i
    f <- f + p
  }
  return(i)
}

# 1. Generate n_sim random samples
