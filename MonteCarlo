# 1. Base data setup
library(bootstrap)
str(law)

# 2. Parameters for Bootstrap
B <- 2000                     # Number of bootstrap replications
alpha <- 0.05                 # Significance level (95% Confidence Interval)
n <- nrow(law)                # Sample size (15)

# Calculate the original sample statistic (Correlation)
theta_hat <- cor(law$LSAT, law$GPA)

# 3. Perform Bootstrap iterations
set.seed(123)                 # For reproducibility
bootstrap_estimates <- numeric(B)

for(i in 1:B) {
  # Resample indices with replacement
  boot_indices <- sample(1:n, size = n, replace = TRUE)
  boot_sample <- law[boot_indices, ]
  
  # Calculate bootstrap statistic
  bootstrap_estimates[i] <- cor(boot_sample$LSAT, boot_sample$GPA)
}

# 4. Calculate BCa Parameters (z0 and a)

# 4-1. Bias-correction parameter (z0)
# Proportion of bootstrap estimates less than or equal to the original estimate
p_le <- mean(bootstrap_estimates <= theta_hat)
z0 <- qnorm(p_le)

# 4-2. Acceleration parameter (a) using Jackknife
jack_estimates <- numeric(n)
for(i in 1:n) {
  jack_sample <- law[-i, ]    # Drop the i-th observation
  jack_estimates[i] <- cor(jack_sample$LSAT, jack_sample$GPA)
}

jack_mean <- mean(jack_estimates)
jack_diff <- jack_mean - jack_estimates

# Calculate acceleration based on skewed third moment (Taylor approximation)
num <- sum(jack_diff^3)
den <- 6 * (sum(jack_diff^2))^(1.5)
a <- num / den

# 5. Calculate Adjusted Percentiles (alpha1 and alpha2)
z_alpha_lower <- qnorm(alpha / 2)
z_alpha_upper <- qnorm(1 - alpha / 2)

# BCa formula for adjusted normal percentiles
adjusted_z1 <- z0 + (z0 + z_alpha_lower) / (1 - a * (z0 + z_alpha_lower))
adjusted_z2 <- z0 + (z0 + z_alpha_upper) / (1 - a * (z0 + z_alpha_upper))

# Convert back to probability scale using CDF (pnorm)
alpha1 <- pnorm(adjusted_z1)
alpha2 <- pnorm(adjusted_z2)

# 6. Find the BCa Bootstrap Confidence Interval
ci_lower <- quantile(bootstrap_estimates, alpha1)
ci_upper <- quantile(bootstrap_estimates, alpha2)

# Print results
cat("Original Estimate (theta_hat):", theta_hat, "\n")
cat("Bias-correction (z0):         ", z0, "\n")
cat("Acceleration (a):             ", a, "\n")
cat(sprintf("Adjusted Percentiles:          alpha1 = %.4f, alpha2 = %.4f\n", alpha1, alpha2))
cat(sprintf("%.0f%% BCa Bootstrap CI:         [%.4f, %.4f]\n", (1 - alpha) * 100, ci_lower, ci_upper))



