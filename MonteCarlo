# 4. Calculate R-hat (Gelman-Rubin) directly
calculate_rhat <- function(chains) {
  n_chains <- length(chains)
  n_iter <- nrow(chains[[1]])
  n_params <- ncol(chains[[1]])
  rhat <- sapply(1:n_params, function(p) {
    x_all <- sapply(chains, function(m) m[, p])
    chain_means <- colMeans(x_all)
    W <- mean(apply(x_all, 2, var))
    B <- n_iter * var(chain_means)
    var_hat <- ((n_iter - 1) / n_iter) * W + (1 / n_iter) * B
    return(sqrt(var_hat / W))
  })
  return(rhat)
}

