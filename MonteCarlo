# 2. Gibbs Sampler Function
run_mcmc_chain <- function(seed, n_iter = 5000) {
  set.seed(seed)
  k <- sample(1:n, 1)
  mu <- mean(x)
  lambda <- mean(x)
  samples <- matrix(NA, nrow = n_iter, ncol = 3)
  colnames(samples) <- c("mu", "lambda", "k")
  
  for (i in 1:n_iter) {
    # Update mu and lambda
    if (k == n) {
      mu <- rgamma(1, shape = 0.001 + sum(x), rate = 0.001 + n)
      lambda <- rgamma(1, shape = 0.001, rate = 0.001)
    } else {
      mu <- rgamma(1, shape = 0.001 + sum(x[1:k]), rate = 0.001 + k)
      lambda <- rgamma(1, shape = 0.001 + sum(x[(k + 1):n]), rate = 0.001 + (n - k))
    }
    # Update k
    log_probs <- sapply(1:n, function(j) {
      if (j == n) sum(dpois(x, mu, log = TRUE))
      else sum(dpois(x[1:j], mu, log = TRUE)) + sum(dpois(x[(j + 1):n], lambda, log = TRUE))
    })
    probs <- exp(log_probs - max(log_probs))
    k <- sample(1:n, 1, prob = probs)
    samples[i, ] <- c(mu, lambda, k)
  }
  return(samples)
}

