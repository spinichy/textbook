# Set parameters
set.seed(123)          # For reproducibility
N <- 10000             # Number of iterations
sigma <- 2             # Parameter for Rayleigh distribution
x <- numeric(N)        # Vector to store chains

# Target log-density function (Rayleigh)
log_f <- function(val, sigma) {
  if (val <= 0) return(-Inf)
  return(log(val) - 2 * log(sigma) - (val^2) / (2 * sigma^2))
}

# Proposal log-density function (Chi-squared with df = current x)
log_q <- function(y, x_current) {
  if (y <= 0 || x_current <= 0) return(-Inf)
  return(dchisq(y, df = x_current, log = TRUE))
}

# Initialization
x[1] <- 1.0            # Initial value X_0 stored at index 1

# Metropolis-Hastings Algorithm loop
for (t in 1:(N - 1)) {
  current_x <- x[t]
  
  # Propose a candidate from Chi-squared distribution with df = current_x
  # Ensure df is positive
  if (current_x <= 0) {
    proposed_y <- 0.01 
  } else {
    proposed_y <- rchisq(1, df = current_x)
  }
  
  # Calculate log acceptance ratio
  log_target_ratio   <- log_f(proposed_y, sigma) - log_f(current_x, sigma)
  log_proposal_ratio <- log_q(current_x, proposed_y) - log_q(proposed_y, current_x)
  log_alpha          <- log_target_ratio + log_proposal_ratio
  
  # Accept or reject
  if (log(runif(1)) < log_alpha) {
    x[t + 1] <- proposed_y     # Accept
  } else {
    x[t + 1] = current_x      # Reject
  }
}

# Diagnostics (Optional: visual check)
hist(x[2000:N], breaks = 50, probability = TRUE, main = "M-H Sampling vs True Rayleigh")
curve(x/sigma^2 * exp(-x^2/(2*sigma^2)), add = TRUE, col = "red", lwd = 2)






