# 1. Define Skewness Function (sk)
# Measures the asymmetry of the data distribution
calc_skewness <- function(x) {
  n <- length(x)
  mean_x <- mean(x)
  m3 <- sum((x - mean_x)^3) / n      # 3rd central moment
  m2 <- sum((x - mean_x)^2) / n      # 2nd central moment (biased variance)
  return(m3 / (m2^(1.5)))
}

# 2. Setup Simulation Parameters
set.seed(42)                         # For reproducibility
n <- 30                              # Sample size specified in the text
alpha <- 0.1                         # Significance level specified in the text
m <- 2000                            # Number of Monte Carlo replications

epsilon_vector <- seq(0, 1, by = 0.1)
power_results <- numeric(length(epsilon_vector))

# 3. Step 1: Find Critical Values under Null Hypothesis (epsilon = 0)
# Under H0, data comes purely from standard normal distribution N(0, 1)
null_skewness <- numeric(m)
for (j in 1:m) {
  null_sample <- rnorm(n, mean = 0, sd = 1)
  null_skewness[j] <- calc_skewness(null_sample)
}

# Two-tailed test critical values (alpha = 0.1 => 5% on each tail)
lower_crit <- quantile(null_skewness, alpha / 2)
upper_crit <- quantile(null_skewness, 1 - alpha / 2)

# 4. Step 2: Run Power Simulation for each Epsilon
for (i in 1:length(epsilon_vector)) {
  eps <- epsilon_vector[i]
  rejection_count <- 0
  
  for (j in 1:m) {
    # Generate Normal Mixture Sample: (1 - eps)*N(0,1) + eps*N(0,100)
    # Step A: Determine components using a binomial/bernoulli trial
    components <- rbinom(n, size = 1, prob = eps)
    
    # Step B: Generate actual sample based on the selected components
    sample_data <- numeric(n)
    for (k in 1:n) {
      if (components[k] == 0) {
        sample_data[k] <- rnorm(1, mean = 0, sd = 1)   # Standard Normal
      } else {
        sample_data[k] <- rnorm(1, mean = 0, sd = 10)  # Contaminated (sd = sqrt(100) = 10)
      }
    }
    
    # Calculate Skewness statistic for the j-th replication
    sk_j <- calc_skewness(sample_data)
    
    # Check if H0 is rejected (if the statistic falls outside the critical values)
    if (sk_j < lower_crit || sk_j > upper_crit) {
      rejection_count <- rejection_count + 1
    }
  }
  
  # Empirical Power: (1/m) * sum(I_j)
  power_results[i] <- rejection_count / m
}

# 5. Combine Results and Print
