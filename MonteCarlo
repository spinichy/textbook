mu2      <- 3.0  # Mean of the second component
sigma2   <- 1.5  # SD of the second component

# Generate synthetic sample data (z_1, ..., z_n)
n_samples <- 300
components <- rbinom(n_samples, size = 1, prob = 1 - true_p) + 1 # 1 or 2

z <- numeric(n_samples)
z[components == 1] <- rnorm(sum(components == 1), mean = mu1, sd = sigma1)
z[components == 2] <- rnorm(sum(components == 2), mean = mu2, sd = sigma2)


# --- 2. Likelihood and Prior Functions ---
mixture_log_likelihood <- function(p, data, m1, s1, m2, s2) {
  if (p <= 0 || p >= 1) return(-Inf)
  f1 <- dnorm(data, mean = m1, sd = s1)
  f2 <- dnorm(data, mean = m2, sd = s2)
  total_density <- p * f1 + (1 - p) * f2
  return(sum(log(total_density)))
}

log_prior <- function(p) {
  if (p <= 0 || p >= 1) return(-Inf)
  return(dbeta(p, shape1 = 1, shape2 = 1, log = TRUE))
}

log_target_posterior <- function(p, data, m1, s1, m2, s2) {
  return(mixture_log_likelihood(p, data, m1, s1, m2, s2) + log_prior(p))
}


