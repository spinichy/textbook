# Define the transition probability matrix P
# Row 1: Today is Rain (R), Row 2: Today is No Rain (N)
# Column 1: Next day is Rain, Column 2: Next day is No Rain
P <- matrix(c(0.7, 0.3, 
              0.4, 0.6), nrow = 2, byrow = TRUE);P

# Initial state: Today it rained (100% chance for Rain, 0% for No Rain)
initial_state <- c(1, 0)

# Calculate the state distribution after two days (P squared)
# Matrix multiplication in R is performed using %*%
two_days_later <- initial_state %*% (P %*% P);two_days_later

# Extract the probability of 'No Rain' (the second element of the result vector)
prob_no_rain_2days <- two_days_later[2]

# Print the final result
print(paste("Probability of No Rain after two days:", prob_no_rain_2days))


