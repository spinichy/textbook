# Load necessary libraries
library(ggplot2)
library(gridExtra)

# 1. Preprocessing: Count the number of disasters per year
data(coal)
years <- floor(coal$date)
year_range <- min(years):max(years)
year_counts <- table(factor(years, levels = year_range))
x <- as.numeric(year_counts)
n <- length(x)

# 2. MCMC (Gibbs Sampler) with k including n (no change point case)
set.seed(2026)
n_iter <- 10000
burn_in <- 2000

# Initialization
k <- floor(n / 2)
mu <- mean(x[1:k])
lambda <- mean(x[(k + 1):n])

# Storage for MCMC samples
samples <- matrix(NA, nrow = n_iter, ncol = 3)
colnames(samples) <- c("mu", "lambda", "k")

# Gibbs Sampling Loop
for (i in 1:n_iter) {
  # Step 1: Update mu
  # If k=n, all data is used for mu
  if (k == n) {
    mu <- rgamma(1, shape = 0.001 + sum(x), rate = 0.001 + n)
    lambda <- rgamma(1, shape = 0.001, rate = 0.001) # lambda becomes independent prior
  } else {
    mu <- rgamma(1, shape = 0.001 + sum(x[1:k]), rate = 0.001 + k)
    lambda <- rgamma(1, shape = 0.001 + sum(x[(k + 1):n]), rate = 0.001 + (n - k))
  }
  
  # Step 2: Update k considering k=n
  log_probs <- sapply(1:n, function(j) {
    if (j == n) {
      # Log-likelihood when there is no change point (all governed by mu)
      sum(dpois(x, mu, log = TRUE))
    } else {
      # Log-likelihood when change occurs at j
      sum(dpois(x[1:j], mu, log = TRUE)) + sum(dpois(x[(j + 1):n], lambda, log = TRUE))
    }
  })
  
  # Normalize probabilities to prevent underflow
  probs <- exp(log_probs - max(log_probs))
  k <- sample(1:n, 1, prob = probs)
  
  samples[i, ] <- c(mu, lambda, k)
}

