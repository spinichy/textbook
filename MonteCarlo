# 3. Multiple Regression CV (U, U^2, U^3)
# 4. Structural CV (Using a structurally similar function whose integral we know)

# 1. Setup
set.seed(202)
n <- 100000
u <- runif(n)
g_u <- exp(-u) / (1 + u^2)

# --- Method 0: Simple Monte Carlo ---
theta_hat_simple <- mean(g_u)
var_simple <- var(g_u) / n

# --- Method A: Single Composite (Hand-derived Taylor) ---
# f_comp = 1 - U - (1/2)U^2 + (5/6)U^3, E[f] = 13/24
f_comp <- 1 - u - 0.5*(u^2) + (5/6)*(u^3)
mu_comp <- 13/24
c_comp <- -cov(g_u, f_comp) / var(f_comp)
theta_hat_A <- mean(g_u + c_comp * (f_comp - mu_comp))
var_A <- var(g_u + c_comp * (f_comp - mu_comp)) / n

# --- Method B: Multiple Regression (Polynomial terms) ---
f1 <- u; f2 <- u^2; f3 <- u^3
mu_v <- c(1/2, 1/3, 1/4)
model_B <- lm(g_u ~ f1 + f2 + f3)
betas_B <- coef(model_B)[-1]
theta_c_B <- g_u - betas_B[1]*(f1 - mu_v[1]) - betas_B[2]*(f2 - mu_v[2]) - betas_B[3]*(f3 - mu_v[3])
theta_hat_B <- mean(theta_c_B)
var_B <- var(theta_c_B) / n

# --- Method C: Structural Similarity (The "Known Function" Approach) ---
# Let's use f(u) = exp(-0.5)/(1 + u^2) as our control variate.
# We know E[f(U)] = exp(-0.5) * pi/4
f_struct <- exp(-0.5) / (1 + u^2)
mu_struct <- exp(-0.5) * (pi / 4)
c_struct <- -cov(g_u, f_struct) / var(f_struct)
theta_hat_C <- mean(g_u + c_struct * (f_struct - mu_struct))
var_C <- var(g_u + c_struct * (f_struct - mu_struct)) / n

# --- Results Comparison ---
results <- data.frame(
  Method = c("Simple MC", "Taylor Composite", "Multiple Reg", "Structural CV"),
  Estimate = c(theta_hat_simple, theta_hat_A, theta_hat_B, theta_hat_C),
  Variance = c(var_simple, var_A, var_B, var_C),
  Reduction_vs_Simple = c(0, 
                          (1 - var_A/var_simple)*100, 
                          (1 - var_B/var_simple)*100, 
                          (1 - var_C/var_simple)*100)
)

print(results)

# --- Visualization ---
boxplot(g_u, (g_u + c_comp*(f_comp - mu_comp)), theta_c_B, (g_u + c_struct*(f_struct - mu_struct)),
        names = c("Simple", "Taylor", "Multi-Reg", "Structural"),
        main = "Comparison of Variance Reduction Techniques",
        col = c("white", "lightblue", "lightgreen", "salmon"),
