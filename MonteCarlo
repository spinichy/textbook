# Define the transition probability matrix P
# Row 1: State 0, Row 2: State 1
P <- matrix(c(1/2, 1/2, 
              1/4, 3/4), nrow = 2, byrow = TRUE)

# Function to calculate P raised to the power of n
matrix_power <- function(mat, n) {
  result <- mat
  if (n > 1) {
    for (i in 2:n) {
      result <- result %*% mat
    }
  }
  return(result)
}

# Calculate P^(n) for a large n (e.g., n = 50) to find the limit
P_limit <- matrix_power(P, 50)

# Print the result
cat("The limit of P^(n) as n goes to infinity:\n")
print(P_limit)


#(b)
# Find the stationary distribution using eigenvalues
# We need the transpose of P for the equation: t(P) %*% pi = pi
eigen_decomp <- eigen(t(P))

# The eigenvector corresponding to the eigenvalue 1 (usually the first one)
stationary_vector <- Re(eigen_decomp$vectors[, 1])

# Normalize the vector so that the sum equals 1
pi_dist <- stationary_vector / sum(stationary_vector)

# Print the stationary distribution
cat("Stationary Distribution (pi):\n")
names(pi_dist) <- c("State 0", "State 1")
print(pi_dist)


