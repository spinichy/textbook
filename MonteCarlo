# Metropolis algorithm for posterior distribution of theta
# Target: Posterior proportional to (2+theta)^125 * (1-theta)^38 * theta^34

set.seed(42)

# Define the log-posterior function (log-likelihood)
log_posterior <- function(theta) {
  if (theta < 0 || theta > 1) return(-Inf) # Constraints on theta
  return(125 * log(2 + theta) + 38 * log(1 - theta) + 34 * log(theta))
}

metropolis_theta <- function(n_iterations, w) {
  samples <- numeric(n_iterations)
  current_theta <- 0.5 # Initial value
  accept_count <- 0
  
  for (i in 1:n_iterations) {
    # Proposal: Uniform(-w, w)
    candidate <- current_theta + runif(1, -w, w)
    
    # Check boundsa
    if (candidate < 0 || candidate > 1) {
      log_ratio <- -Inf
    } else {
      log_ratio <- log_posterior(candidate) - log_posterior(current_theta)
    }
    
    if (log(runif(1)) < log_ratio) {
      current_theta <- candidate
      accept_count <- accept_count + 1
    }
    samples[i] <- current_theta
  }
  return(list(samples = samples, accept_rate = accept_count / n_iterations))
}

# Run simulation
result <- metropolis_theta(10000, 0.1)

# Plot posterior distribution
hist(result$samples, breaks=50, prob=TRUE, main="Posterior Distribution of Theta", xlab="theta")
cat("Acceptance Rate:", result$accept_rate * 100, "%\n")


