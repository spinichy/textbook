# 1. Create the Contingency Table
# Row 1: Heart Disease (5, 25), Row 2: No Heart Disease (2, 28)
# Fixed marginal totals: Row totals (30, 30), Column totals (7, 53)
data_matrix <- matrix(c(5, 25, 2, 28), 
                      nrow = 2, byrow = TRUE,
                      dimnames = list(Condition = c("Heart_Disease", "No_Heart_Disease"),
                                      Salt_Intake = c("High_Salt", "Low_Salt")))

# Check the table
print("--- Contingency Table ---")
print(data_matrix)


# 2. Chi-squared Test (Asymptotic Method)
# This uses the formula (O-E)^2 / E
# Note: R will likely give a warning because expected frequencies are small.
chi_result <- chisq.test(data_matrix, correct = FALSE)

print("--- Chi-squared Test Result ---")
print(chi_result)

# Check Expected Frequencies (E)
# If any E < 5, the p-value above might be unreliable.
print("Expected Frequencies:")
print(chi_result$expected)


# 3. Permutation Test (Monte Carlo Simulation)
# This is the "Randomly Shuffling" method we discussed.
# It keeps the original proportions (marginal totals) and shuffles labels M times.
# B = 10000 is the number of random trials to reduce variance of the p-value.
perm_test_result <- chisq.test(data_matrix, simulate.p.value = TRUE, B = 10000)

print("--- Randomized Permutation Test (Monte Carlo) ---")
print(perm_test_result)


# 4. Fisher's Exact Test (Exact Permutation for 2x2)
# This calculates the exact p-value by considering ALL possible permutations.
# Most reliable for small sample sizes.
