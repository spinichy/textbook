group_old <- runif(n_old, min = 10, max = 100)

all_data <- c(group_new, group_old)
n_total <- length(all_data)

# 2. Define Test Statistic Functions (English Comments)
stats_list <- list(
  # Sum of observations for Group New
  Sum_Y        = function(y, x) sum(y),
  
  # Standard t-statistic (assuming equal variance for calculation)
  T_Stat       = function(y, x) t.test(y, x, var.equal = TRUE)$statistic,
  
  # Difference in medians (New - Old)
  Median_Diff  = function(y, x) median(y) - median(x),
  
  # 10% Trimmed Mean Difference
  Trimmed_Diff = function(y, x) mean(y, trim = 0.05) - mean(x, trim = 0.05)
)

# 3. Monte Carlo Simulation (10,000 iterations)
n_iter <- 10000
null_distributions <- list()

for (name in names(stats_list)) {
  # Generate null distribution by randomly shuffling group labels
  null_distributions[[name]] <- replicate(n_iter, {
    shuffled_idx <- sample(1:n_total, n_new)
    stats_list[[name]](all_data[shuffled_idx], all_data[-shuffled_idx])
  })
}

# 4. Calculate Observed Stats and P-values
cat("--- Results with Uniform Distribution (n=60) ---\n")
for (name in names(stats_list)) {
  # Calculate actual observed statistic from the generated data
  obs_val <- stats_list[[name]](group_new, group_old)
  
  # Calculate p-value (Lower tail: New is expected to be smaller than Old)
  p_val <- sum(null_distributions[[name]] <= obs_val) / n_iter
  
  cat(sprintf("[%s]\n Observed Value: %.3f | P-value: %.4f\n\n", 
              name, obs_val, p_val))
}


