obs_diff <- mean(group_new) - mean(group_trad)
# Standard two-sample t-test (assuming equal variance for consistency in permutation)
obs_t <- t.test(group_new, group_trad, var.equal = TRUE)$statistic

# 3. Exact Permutation (All 7C4 = 35 combinations)
combinations <- combn(1:total_n, m)
num_perms <- ncol(combinations)

perm_diffs <- numeric(num_perms)
perm_t_stats <- numeric(num_perms)

for (i in 1:num_perms) {
  # Partition the data based on current combination indices
  idx <- combinations[, i]
  g1 <- combined[idx]
  g2 <- combined[-idx]
  
  # Calculate D (mean difference) and T (t-statistic) for each case
  perm_diffs[i] <- mean(g1) - mean(g2)
  perm_t_stats[i] <- t.test(g1, g2, var.equal = TRUE)$statistic
}

# 4. P-value Calculations
# One-sided (H1: New treatment reduces recovery time -> D < 0)
p_one_D <- sum(perm_diffs <= obs_diff) / num_perms
p_one_T <- sum(perm_t_stats <= obs_t) / num_perms

# Two-sided (H1: Any difference exists -> |D| is large)
p_two_D <- sum(abs(perm_diffs) >= abs(obs_diff)) / num_perms
p_two_T <- sum(abs(perm_t_stats) >= abs(obs_t)) / num_perms

