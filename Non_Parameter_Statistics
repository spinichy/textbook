# 1. Input data and null hypothesis value
x <- c(11, 20, 16, 5, 3, 17)
theta_0 <- 15

# 2. Step-by-step calculation for understanding
diff <- x - theta_0          # Difference (Xi - theta_0)
abs_diff <- abs(diff)       # Absolute difference |Xi - theta_0|
sign_val <- sign(diff)      # Sign of the difference (+1 or -1)
ranks <- rank(abs_diff)     # Ranks based on absolute differences

# Create a summary table to match the textbook example
calculation_table <- data.frame(
  Observation = x,
  Difference = diff,
  Abs_Difference = abs_diff,
  Sign = sign_val,
  Rank = ranks,
  Signed_Rank = sign_val * ranks
)

# 3. Calculate Wilcoxon Statistics (W+ and W-)
w_plus <- sum(ranks[diff > 0])
w_minus <- sum(ranks[diff < 0])

# 4. Perform the exact Wilcoxon Signed-Rank Test using R's built-in function
# 'exact = TRUE' is recommended for small sample sizes
test_result <- wilcox.test(x, mu = theta_0, alternative = "two.sided", 
                           conf.int = TRUE, exact = TRUE)

# 5. Display Results
print("--- Step-by-Step Calculation Table ---")
print(calculation_table)

cat("\n--- Wilcoxon Test Statistics ---",
    "\nW+ (Sum of positive ranks):", w_plus,
    "\nW- (Sum of negative ranks):", w_minus,
    "\nTotal Sum of Ranks [n(n+1)/2]:", sum(ranks), "\n")

cat("\n--- R built-in wilcox.test Output ---",
    "\nV (Test Statistic):", test_result$statistic,
    "\nP-value:", test_result$p.value, "\n")

