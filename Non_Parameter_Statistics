# 2. Skillings-Mack Statistic Function
calc_SM <- function(data) {
  # Parameters based on your notation
  b <- length(unique(data$block))
  k <- length(unique(data$treatment))
  n_total <- nrow(data)
  c_rep <- n_total / (b * k)
  kc <- k * c_rep
  
  # Ranking within each block (Fixing the 'ave' error by using split)
  # Split x by block, apply rank, and unsplit to maintain order
  data$ranks <- unsplit(lapply(split(data$x, data$block), rank), data$block)
  
  # Calculate Rbar_i.. (Mean rank for each treatment)
  Rbar_i <- as.numeric(tapply(data$ranks, data$treatment, mean))
  
  # Calculate Rbar_... (Global mean rank)
  Rbar_all <- (kc + 1) / 2
  
  
  
  # SM Formula
  # SM = (12 * b / (kc * (kc + 1))) * sum((Rbar_i - Rbar_all)^2)
  SM <- (12 * b / (kc * (kc + 1))) * sum((Rbar_i - Rbar_all)^2)
  
  return(SM)
}

# 3. Execution & Permutation Test
