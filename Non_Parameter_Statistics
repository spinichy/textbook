# Function to calculate bootstrap SE and Bias
run_bootstrap <- function(data, n_size, b_reps) {
  # Step 1: Draw a sample of size n from the original population
  current_sample <- sample(data, size = n_size, replace = FALSE)
  sample_mean <- mean(current_sample)
  
  # Step 2: Generate Bootstrap distribution
  boot_means <- replicate(b_reps, {
    # Resample with replacement from the current sample
    resample <- sample(current_sample, size = n_size, replace = TRUE)
    mean(resample)
  })
  
  # Step 3: Calculate Bootstrap SE and Bias
  boot_se <- sd(boot_means)
  # Bias = Mean of Bootstrap estimates - Original sample estimate
  boot_bias <- mean(boot_means) - sample_mean
  
  return(c(SE = boot_se, Bias = boot_bias))
}

# 3. Execution Loop
