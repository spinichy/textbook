# 2. Function to calculate JT Statistic (T)
calc_jt_stat <- function(lst) {
  k <- length(lst)
  t_stat <- 0
  
  # Outer loops for group pairs (i < j)
  for (i in 1:(k - 1)) {
    for (j in (i + 1):k) {
      
      # Inner loops to calculate Mann-Whitney U for each pair
      u_ij <- 0
      for (val_i in lst[[i]]) {
        for (val_j in lst[[j]]) {
          if (val_i < val_j) {
            u_ij <- u_ij + 1
          } else if (val_i == val_j) {
            u_ij <- u_ij + 0.5
          }
        }
      }
      t_stat <- t_stat + u_ij
    }
  }
  return(t_stat)
}

