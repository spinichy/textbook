# 1. Data input and basic setup
# Sorted data from previous example
x <- sort(c(1200, 2300, 5800, 1100, 1200, 1700, 1400, 1900, 3800, 1300))
n <- length(x)
alpha <- 0.05

# 2. Find the largest 'l' such that P(S <= l-1) <= alpha/2
# S follows Binomial distribution B(n, 0.5)
# pbinom(k, n, p) calculates P(S <= k)
l_candidates <- 1:(n/2)
probabilities <- pbinom(l_candidates - 1, n, 0.5)

# Select the largest l that satisfies the condition
l <- max(l_candidates[probabilities <= alpha/2])

# 3. Determine the rank of upper bound: u = n - l + 1
u <- n - l + 1

# 4. Extract the confidence interval from order statistics
conf_interval <- c(x[l], x[u])

# 5. Calculate exact confidence level
# The actual confidence level is 1 - 2 * P(S <= l-1)
exact_alpha <- 2 * pbinom(l - 1, n, 0.5)
exact_conf_level <- 1 - exact_alpha

# 6. Display results
cat("--- Result Based on Order Statistics ---\n")
cat("Sample Size (n):", n, "\n")
cat("Rank for Lower Bound (l):", l, "\n")
cat("Rank for Upper Bound (u):", u, "\n")
cat("95% Confidence Interval: [", conf_interval[1], ",", conf_interval[2], "]\n")
cat("Actual Confidence Level:", round(exact_conf_level * 100, 2), "%\n")

