# where p is the probability related to the specific percentile.
# Testing if at least 90% break after 10 (i.e., P(X > 10) <= 0.1)
p_value <- 1 - pbinom(q = plus_signs - 1, size = n, prob = 0.1)

cat("--- Sign Test Results --- \n")
cat("Number of observations > 10: ", plus_signs, "\n")
cat("P-value: ", p_value, "\n")
if(p_value < 0.1) {
  cat("Result: Reject H0 at alpha=0.1. Significant evidence that the device lasts over 100,000 times.\n")
} else {
  cat("Result: Fail to reject H0. Insufficient evidence.\n")
}

