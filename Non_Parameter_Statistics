# 2. Define Negative Log-Likelihood function for Weibull
# parameters[1] = shape (k), parameters[2] = scale (lambda)
weibull_loglik <- function(params, data) {
  
  # Here, 'params' is a placeholder for the vector c(shape, scale) 
  # that will be passed from the optim() function.
  k <- params[1]
  lambda <- params[2]
  
  # Return a very large value if parameters are non-positive (constraint)
  if (k <= 0 || lambda <= 0) return(1e10)
  
  # Calculate Negative Log-Likelihood
  # sum(log(pdf))
  loglik <- sum(dweibull(data, shape = k, scale = lambda, log = TRUE))
  return(-loglik) # Negative for minimization
}

# 3. Estimate Parameters using optim()
# Initial guesses: shape = 2, scale = mean(data)
initial_guess <- c(2, mean(wind_data))
fit <- optim(par = initial_guess, fn = weibull_loglik, data = wind_data)

k_est <- fit$par[1]
lambda_est <- fit$par[2]

cat("--- Weibull Parameter Estimation (Base R) ---\n")
cat("Shape Parameter (k): ", k_est, "\n")
