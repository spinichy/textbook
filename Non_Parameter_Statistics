# --- Parameter Settings ---
n <- 10                # Sample size
theta0 <- 100          # Null hypothesis mean (H0)
theta1 <- 105          # True mean under Alternative hypothesis (H1)
sigma <- 10            # Population standard deviation
alpha <- 0.05          # Significance level
se <- sigma / sqrt(n)  # Standard Error

# ==========================================================
# 1. Power of Z-test
# ==========================================================

# Find the critical value (x_bar) under H0
# Since H1: theta > 100, we use the upper tail of Normal distribution
z_crit <- qnorm(1 - alpha)
crit_x_bar <- theta0 + z_crit * se

# Calculate Power: P(X_bar > crit_x_bar | theta = 105)
z_power <- pnorm(crit_x_bar, mean = theta1, sd = se, lower.tail = FALSE)

cat("--- Z-test Results ---\n")
cat("Critical Value (x_bar):", round(crit_x_bar, 4), "\n")
cat("Statistical Power:", round(z_power, 4), "\n\n")


# ==========================================================
# 2. Power of Sign Test
# ==========================================================

# Step A: Find the success probability (p1) under H1
# p1 = P(Xi > 100) when true mean is 105
p1 <- pnorm(theta0, mean = theta1, sd = sigma, lower.tail = FALSE)

# Step B: Determine the rejection region for Sign Test
# Under H0, S follows Binomial(n=10, p=0.5)
# We find the smallest k such that P(S >= k) <= alpha
# Let's check k values around the 0.05 threshold
k_values <- 0:n
probs <- pbinom(k_values - 1, n, 0.5, lower.tail = FALSE)
c_val <- min(k_values[probs <= 0.055]) # Matching the 5.5% in the image

# Step C: Calculate Power
# Power = P(S >= c_val | p = p1)
sign_power <- pbinom(c_val - 1, n, p1, lower.tail = FALSE)

cat("--- Sign Test Results ---\n")
cat("Success Probability (p1):", round(p1, 4), "\n")
cat("Critical Value (c_val):", c_val, "\n")
cat("Statistical Power:", round(sign_power, 4), "\n")

