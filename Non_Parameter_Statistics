# 2. Function to calculate Friedman Statistic
# Formula: Chi-sq = [12 / nk(k+1)] * Sum(R_j^2) - 3n(k+1)
calc_friedman_stat <- function(mat) {
  n <- nrow(mat) # Number of singers (11)
  k <- ncol(mat) # Number of judges (3)
  
  # Step 1: Rank scores within each judge (row-wise ranking for blocks)
  # Here we need to rank across columns for each row
  ranks <- t(apply(mat, 1, rank)) 
  
  # Step 2: Sum of ranks for each singer (column sums)
  rank_sums <- colSums(ranks)
  
  # Step 3: Apply the formula
  stat <- (12 / (n * k * (k + 1))) * sum(rank_sums^2) - 3 * n * (k + 1)
  return(stat)
}

# 3. Simulate Null Distribution using Permutation
