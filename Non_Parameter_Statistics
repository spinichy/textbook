# 2. Function to calculate statistics
# English comment: Function to get Chi-square and Odds Ratio
get_stats <- function(tab) {
  # Chi-square statistic
  chi_sq <- chisq.test(tab, correct = FALSE)$statistic
  
  # Odds Ratio: (a*d) / (b*c)
  or <- (tab[1,1] * tab[2,2]) / (tab[1,2] * tab[2,1])
  
  return(c(chi_sq = chi_sq, or = or))
}

obs_stats <- get_stats(observed_table)

# 3. Permutation Test (M = 10,000)
set.seed(123)
M <- 10000
perm_chi <- numeric(M)
perm_or <- numeric(M)

for (i in 1:M) {
  # Shuffle one variable to break the association
  perm_salt <- sample(salt_intake)
  perm_table <- table(disease_status, perm_salt)
  
  stats <- get_stats(perm_table)
  perm_chi[i] <- stats["chi_sq.X-squared"]
  perm_or[i] <- stats["or"]
}

# 4. P-value Calculation
