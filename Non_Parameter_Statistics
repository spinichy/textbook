# 1. Setup (n=6)
n <- 6
rank_values <- 1:n

# 2. 모든 2^n (64가지) 조합의 W+ 합 계산
all_combinations <- expand.grid(replicate(n, c(0, 1), simplify = FALSE))
w_plus_distributions <- apply(all_combinations, 1, function(row) sum(row * rank_values))

# 3. 도수분포표 생성
