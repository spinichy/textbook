# Parameter settings for Laplace distribution
# variance = 2 * b^2 = 100, so b = sqrt(50)
b <- sqrt(50)
theta0 <- 100
theta1 <- 105
n <- 10
alpha <- 0.05

# 1. Power of Sign Test under Laplace
# Success probability p1 = P(Xi > 100)
# For x < mu: F(x) = 1/2 * exp((x-mu)/b)
p1_laplace <- 1 - (0.5 * exp((theta0 - theta1) / b))

# Rejection region: S >= 8 (same as before, alpha approx 0.055)
sign_power_laplace <- pbinom(7, n, p1_laplace, lower.tail = FALSE)

# 2. Power of Z-test under Laplace (Z-test assumes normality)
# Note: Z-test is no longer the UMP test here, but we check its performance
se <- 10 / sqrt(n)
crit_x_bar <- theta0 + qnorm(0.95) * se

# Under Laplace, sample mean of n=10 is approximately normal by CLT
z_power_laplace <- pnorm(crit_x_bar, mean = theta1, sd = se, lower.tail = FALSE)

cat("--- Laplace Distribution Results ---\n")
cat("Success Probability (p1):", round(p1_laplace, 4), "\n")
cat("Sign Test Power:", round(sign_power_laplace, 4), "\n")
cat("Z-test Power (Approx):", round(z_power_laplace, 4), "\n")

