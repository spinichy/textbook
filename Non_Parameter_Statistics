# 1. Data Input
# Original data includes 0, which should be handled according to Wilcoxon rules
toy.data <- c(-3, -2, -2, 0, 1, 2, 4, 8, 11, 11)
theta0 <- 0
dev <- toy.data - theta0

# 2. Step 1: Filter out zero differences
# Traditional Wilcoxon signed-rank test discards zero values
dev_filtered <- dev[dev != 0]
n <- length(dev_filtered) # n decreases from 10 to 9

# 3. Step 2: Calculate absolute values and assign ranks
# Use 'average' method for ties (Mid-rank method)
abs_dev <- abs(dev_filtered)
ranks <- rank(abs_dev, ties.method = "average")

# 4. Step 3: Calculate the Test Statistic (SR+)
# Create indicator vector: 1 if positive, 0 otherwise
v_i <- as.numeric(dev_filtered > 0)
sr_plus <- sum(v_i * ranks)

# 5. Step 4: Variance correction for ties
# If ties exist, the variance formula must be adjusted
mu_w <- n * (n + 1) / 4
var_base <- n * (n + 1) * (2 * n + 1) / 24

# Count occurrences of each absolute value to find ties
t_j <- table(abs_dev)
t_j <- t_j[t_j > 1] # Identify groups with ties
tie_correction <- sum(t_j^3 - t_j) / 48
var_corrected <- var_base - tie_correction

# 6. Step 5: Normal Approximation (Z-test)
# Continuity correction (0.5) is often applied for better approximation
z_stat <- (sr_plus - mu_w) / sqrt(var_corrected)
p_value <- pnorm(z_stat, lower.tail = FALSE)

# 7. Output Results
cat("--- Manual Calculation Results ---\n")
cat("Filtered n:", n, "\n")
cat("Test Statistic (SR+):", sr_plus, "\n")
cat("Corrected Variance:", var_corrected, "\n")
cat("Z-statistic:", z_stat, "\n")
cat("P-value (Greater):", p_value, "\n")

