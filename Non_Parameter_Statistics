cat("Mean of Null Distribution:", mu_w, "\n")
cat("Extreme cases (W >= 8 or W <= 4):", extreme_cases, "\n")
cat("Two-sided P-value (Exact):", p_value_two_sided, "(", extreme_cases, "/ 35 )\n")


