# Load necessary library for Laplace distribution
library(rmutil)

# 1. Function to generate Slash distribution: X = theta + Z/U
rslash <- function(n, theta) {
  z <- rnorm(n)
  u <- runif(n)
  return(theta + (z / u))
}

# 2. Simulation Function to calculate Rejection Rate (Power)
# Tests: t-test, Sign test, Wilcoxon Signed-Rank test
get_power <- function(n, dist_type, theta, n_sim = 1000, alpha = 0.05) {
  rejections <- data.frame(t_test = logical(n_sim), 
                           sign_test = logical(n_sim), 
                           wilcox_test = logical(n_sim))
  
  for(i in 1:n_sim) {
    # Generate data based on distribution and theta
    if(dist_type == "Normal") {
      x <- rnorm(n, mean = theta, sd = 1)
    } else if(dist_type == "Laplace") {
      x <- rlaplace(n, m = theta, s = 1)
    } else if(dist_type == "Slash") {
      x <- rslash(n, theta = theta)
    }
    
    # Perform 3 types of tests (H0: theta = 0)
    rejections$t_test[i] <- t.test(x = x, mu = 0)$p.value < alpha
    rejections$sign_test[i] <- binom.test(sum(x > 0), n, p = 0.5)$p.value < alpha
    rejections$wilcox_test[i] <- wilcox.test(x = x, mu = 0)$p.value < alpha
  }
  
  # Calculate power (proportion of rejections)
  return(colMeans(rejections))
}

# 3. Main Simulation Execution
set.seed(123)
theta_val <- 1/4
n_sizes <- c(10, 100)
distributions <- c("Normal", "Laplace", "Slash")

# Create an empty data frame to store results
final_table <- data.frame()

for (n in n_sizes) {
  for (dist in distributions) {
    # Run simulation for each combination
    power_results <- get_power(n, dist, theta_val)
    
    # Organize into a row
    row_data <- data.frame(
      Sample_Size = n,
      Distribution = dist,
      T_Test = round(power_results["t_test"], 3),
      Sign_Test = round(power_results["sign_test"], 3),
      Wilcoxon_Test = round(power_results["wilcox_test"], 3)
    )
    final_table <- rbind(final_table, row_data)
  }
}

# 4. Display the Final Table
cat("--- Power Simulation Results Table ---\n")
print(final_table, row.names = FALSE)


