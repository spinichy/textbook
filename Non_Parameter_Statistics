# 1. Simple dataset
x <- c(1, 2, 3, 4, 5)
y <- c(1, 3, 2, 5, 4)

n <- length(x)
concordant <- 0
discordant <- 0

# 2. Iterate through all possible pairs (i < j)
for (i in 1:(n - 1)) {
  for (j in (i + 1):n) {
    
    # Calculate the product of differences (the sgn function principle)
    pair_relation <- (x[i] - x[j]) * (y[i] - y[j])
    
    if (pair_relation > 0) {
      concordant <- concordant + 1     # Concordant pair (C)
    } else if (pair_relation < 0) {
      discordant <- discordant + 1     # Discordant pair (D)
    }
  }
}

# 3. Calculate Tau based on the formula
total_pairs <- n * (n - 1) / 2
tau_manual <- (concordant - discordant) / total_pairs

# 4. Compare results
print(paste("Number of Concordant pairs (C):", concordant))
print(paste("Number of Discordant pairs (D):", discordant))
print(paste("Manually calculated Tau:", tau_manual))

