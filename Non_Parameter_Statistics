obs_rank_sum <- sum(all_ranks[1:n1]) # 14
w_obs <- obs_rank_sum - (n1 * (n1 + 1)) / 2 # 8

# 3. Generate the Null Distribution (All 35 combinations)
combos <- combn(all_ranks, n1)
null_w_dist <- colSums(combos) - (n1 * (n1 + 1)) / 2

# 4. Two-sided P-value calculation
# Logic: Sum probabilities of values as extreme as or more extreme than w_obs 
# on BOTH sides of the mean (Mean of W is n1*n2 / 2 = 6)

# Expected mean of W under Null Hypothesis
mu_w <- (n1 * n2) / 2 # 6

# Distance from the mean
distance <- abs(w_obs - mu_w) # |8 - 6| = 2

# Find values that are at least 'distance' away from the mean (6)
# Upper extreme: W >= 8
# Lower extreme: W <= 4 (Since 6 - 2 = 4)
extreme_cases <- sum(null_w_dist >= (mu_w + distance) | null_w_dist <= (mu_w - distance))
total_cases <- length(null_w_dist) # 35

p_value_two_sided <- extreme_cases / total_cases

# 5. Print the results
