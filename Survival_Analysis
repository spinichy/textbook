# 1. Define functions based on the provided table

# Partial Likelihood function
partial_lik <- function(b) {
  p1 <- exp(2*b) / (exp(2*b) + exp(2*b) + exp(1*b) + exp(3*b))
  p2 <- exp(1*b) / (exp(1*b) + exp(3*b))
  p3 <- exp(3*b) / (exp(3*b))
  return(p1 * p2 * p3)
}

# Log Partial Likelihood function
log_partial_lik <- function(b) {
  term1 <- 2*b - log(exp(2*b) + exp(2*b) + exp(1*b) + exp(3*b))
  term2 <- 1*b - log(exp(1*b) + exp(3*b))
  term3 <- 3*b - log(exp(3*b))
  return(term1 + term2 + term3)
}

# 2. Prepare data for plotting
