# Function to calculate contributions and total likelihood
get_cox_details_fixed <- function(beta) {
  df <- all_data[order(all_data$time), ]
  # Only consider times where an event (delta=1) occurred
  event_times <- sort(unique(df$time[df$delta == 1]))
  
  contributions <- c()
  risk_set_0 <- c()
  risk_set_1 <- c()
  
  for (t in event_times) {
    # Risk Set: Anyone still in the study at time t (time >= t)
    at_risk <- df[df$time >= t, ]
    n0 <- sum(at_risk$z == 0)
    n1 <- sum(at_risk$z == 1)
    
    # Identify who had the event at exactly time t
    events_at_t <- df[df$time == t & df$delta == 1, ]
    
    for (i in 1:nrow(events_at_t)) {
      z_val <- events_at_t$z[i]
      denom <- n0 * exp(0 * beta) + n1 * exp(1 * beta)
      numer <- exp(z_val * beta)
      prob  <- numer / denom
      
      contributions <- c(contributions, prob)
      risk_set_0 <- c(risk_set_0, n0)
      risk_set_1 <- c(risk_set_1, n1)
    }
  }
  
  res_table <- data.frame(
    Time = event_times,
    n0 = risk_set_0,
    n1 = risk_set_1,
    Contribution = contributions
  )
  
  return(list(table = res_table, total_lik = prod(contributions)))
}

