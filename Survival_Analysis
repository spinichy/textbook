#partial likelihood 


# Analyze partial likelihood contributions for all time points
# beta = 0.1 as an example
analyze_likelihood <- function(beta, data) {
  data <- data[order(data$t), ]
  results <- list()
  
  for (i in 1:nrow(data)) {
    current_t <- data$t[i]
    is_event <- data$delta[i] == 1
    
    # Risk Set: Subjects with survival time >= current time
    risk_set <- data[data$t >= current_t, ]
    risk_ids <- paste(risk_set$id, collapse = ", ")
    
    if (is_event) {
      # Partial Likelihood Contribution: exp(Zi*beta) / Sum(exp(Zj*beta))
      num <- exp(data$z[i] * beta)
      den <- sum(exp(risk_set$z * beta))
      contribution <- num / den
      log_lik <- log(contribution)
    } else {
      # Censored subjects do not contribute to the partial likelihood product
      contribution <- NA
      log_lik <- 0 # Log(1) = 0, so no change to the sum
    }
    
    results[[i]] <- data.frame(
      Time = current_t,
      ID = data$id[i],
      Status = ifelse(is_event, "Event", "Censored"),
      Z = data$z[i],
      Risk_Set = risk_ids,
      Contribution = contribution,
      Log_Lik = log_lik
    )
  }
  return(do.call(rbind, results))
}

