# 2. Manual calculation for Effective Sample Size logic
# We create a function to calculate Hazard and Survival using Y' = Y - c/2
calc_effective_na <- function(data) {
  # Sort by time
  data <- data[order(data$time), ]
  unique_times <- unique(data$time)
  
  results <- data.frame(time = unique_times)
  y_at_risk <- c()
  events <- c()
  censored <- c()
  
  n <- nrow(data)
  for(t in unique_times) {
    y_at_risk <- c(y_at_risk, n)
    d_i <- sum(data$time == t & data$status == 1)
    c_i <- sum(data$time == t & data$status == 0)
    events <- c(events, d_i)
    censored <- c(censored, c_i)
    n <- n - d_i - c_i
  }
  
  # Calculate Effective Sample Size: Y' = Y - c/2
  results$Y_prime <- y_at_risk - (censored / 2)
  results$deaths <- events
  
  # Nelson-Aalen logic with Effective Size
  results$hazard <- results$deaths / results$Y_prime
  results$cum_hazard <- cumsum(results$hazard)
  results$survival <- exp(-results$cum_hazard)
  
  return(results)
}

