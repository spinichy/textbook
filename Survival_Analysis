# 2. Create a sequence of time for prediction
time_seq <- seq(0, 160, length.out = 100)

# 3. Predict survival probabilities
# Function to calculate survival: S(t) = exp(-(t / exp(linear_predictor))^(1/scale))
get_surv_df <- function(model, dist_name) {
  # Predict for both levels of x: Maintained and Nonmaintained
  pred_maintained <- predict(model, newdata = data.frame(x = "Maintained"), type = "lp") #lp: Linear Predictor
  pred_nonmaintained <- predict(model, newdata = data.frame(x = "Nonmaintained"), type = "lp") #lp: Linear Predictor
  
  scale_val <- model$scale
  
  df <- data.frame(
    time = rep(time_seq, 2),
    surv = c(exp(-(time_seq / exp(pred_maintained))^(1/scale_val)),
             exp(-(time_seq / exp(pred_nonmaintained))^(1/scale_val))),
    group = rep(c("Maintained", "Nonmaintained"), each = 100),
    model = dist_name
  )
  return(df)
}
