# Function to calculate Partial Log-Likelihood
calc_partial_loglik <- function(beta, data) {
  # Sort data by time to identify Risk Sets easily
  # Log-likelihood starts at 0
  data <- data[order(data$t), ]
  loglik <- 0
  
  # Loop through each observation where an event occurred (delta == 1)
  for (i in 1:nrow(data)) {
    if (data$delta[i] == 1) {
      current_t <- data$t[i]
      
      # Define Risk Set: people whose survival time is >= current event time
      risk_set <- data[data$t >= current_t, ]
      
      # Log(numerator) - Log(denominator)
      term <- (data$z[i] * beta) - log(sum(exp(risk_set$z * beta)))
      loglik <- loglik + term
    }
  }
  return(loglik)
}
