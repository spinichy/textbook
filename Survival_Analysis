# Weibull AFT Model using Newton-Raphson with k (Shape) and mu (Intercept)
library(survival)

# 1. Data Preparation
y <- log(leukemia$time)   # Log-survival time
delta <- leukemia$status  # Status (1=event, 0=censored)
n <- length(y)

# 2. Log-likelihood Function with k and mu
# Relation: k = 1/sigma, so sigma = 1/k and log_sigma = -log(k)
log_lik <- function(mu, k) {
  sigma <- 1/k
  log_sigma <- -log(k)
  w <- (y - mu) / sigma
  
  # Log-likelihood using explicit k and mu
  val <- sum(delta * (w - log_sigma) - exp(w))
  return(val)
}

# 3. Function to Calculate Score and Hessian using k and mu
get_score_and_hessian <- function(mu, k) {
  sigma <- 1/k
  log_sigma <- -log(k)
  w <- (y - mu) / sigma
  exp_w <- exp(w)
  
  # --- Score Vector (First Derivatives) ---
  # Derivatives are still computed with respect to mu and log_sigma 
  # for numerical stability during the Newton step
  s_mu <- (1/sigma) * sum(exp_w - delta)
  s_log_sigma <- sum(w * (exp_w - delta) - delta)
  
  score_vec <- c(s_mu, s_log_sigma)
  
  # --- Hessian Matrix (Second Derivatives) ---
  h_mu_mu <- (-1/sigma^2) * sum(exp_w)
  h_mu_ls <- (-1/sigma) * sum(w * exp_w + exp_w - delta)
  h_ls_ls <- -sum(w^2 * exp_w + w * exp_w - w * delta)
  
  hessian_mat <- matrix(c(h_mu_mu, h_mu_ls, h_mu_ls, h_ls_ls), 2, 2)
  
  return(list(score = score_vec, hessian = hessian_mat))
}

# 4. Newton-Raphson Iterative Optimization
# Initial values: k=1 (Exponential case), mu=mean(y)
current_mu <- mean(y)
current_k <- 1.0 

cat("Starting Newton-Raphson with k (Shape) and mu (Intercept)...\n\n")

for (i in 1:10) {
  # Inside the loop, we map k back to log_sigma for the Newton step
  current_log_sigma <- -log(current_k)
  
  # Get gradients and curvature
  sh <- get_score_and_hessian(current_mu, current_k)
  
  # Solve for the update step
  step <- solve(sh$hessian) %*% sh$score
  
  # Update parameters
  current_mu        <- current_mu - step[1]
  current_log_sigma <- current_log_sigma - step[2]
  
  # Convert log_sigma back to k for the next iteration and display
  current_k <- exp(-current_log_sigma)
  
  # Monitor Likelihood
  ll <- log_lik(current_mu, current_k)
  cat(sprintf("Iteration %d: Log-lik = %.4f, mu = %.4f, k = %.4f\n", 
              i, ll, current_mu, current_k))
  
  # Convergence check
  if (max(abs(sh$score)) < 1e-6) {
    cat("\nConverged!\n")
    break
  }
}

# 5. Final Summary
final_log_sigma <- -log(current_k)
final_sh <- get_score_and_hessian(current_mu, current_k)
vcv <- solve(-final_sh$hessian)
se <- sqrt(diag(vcv))

results <- data.frame(
  Estimate = c(current_mu, final_log_sigma),
  Std_Error = se,
  row.names = c("(Intercept)", "Log(scale)")
)

cat("\nFinal Results (Matching survreg output):\n")
print(results)
cat(sprintf("\nFinal Shape (k): %.4f\n", current_k))
cat(sprintf("Final Scale (sigma): %.4f\n", 1/current_k))



