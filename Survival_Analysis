    event_z <- df$z[df$time == t & df$delta == 1]
    
    for (z_val in event_z) {
      denom <- n0 * exp(0 * beta) + n1 * exp(1 * beta)
      log_lik <- log_lik + (z_val * beta - log(denom))
    }
  }
  return(-log_lik) # Return negative for minimization
}

