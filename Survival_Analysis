  tongue_data %>% 
    filter(status == 1) %>% 
    group_by(group) %>% 
    summarise(avg_time = mean(time)) %>% 
    mutate(analysis_type = "Observed Only"),
  
  tongue_data %>% 
    group_by(group) %>% 
    summarise(avg_time = mean(time)) %>% 
    mutate(analysis_type = "Observed + Censored")
) %>%
  mutate(analysis_type = factor(analysis_type, 
                                levels = c("Observed Only", "Observed + Censored")))

