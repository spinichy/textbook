  status = c(1, 1, 1, 0, 1, 0, 0, 0, 0, 0)
)

# ---------------------------------------------------------
# 2. Survival Calculations
# ---------------------------------------------------------
event_times <- sort(unique(df_raw$time[df_raw$status == 1]))
res <- data.frame(Time = event_times)

# n_i: Number at risk, d_i: Number of events
res$n_i <- sapply(res$Time, function(t) sum(df_raw$time >= t))
res$d_i <- sapply(res$Time, function(t) sum(df_raw$time == t & df_raw$status == 1))

# c_i: Censoring count between events
event_times_ext <- c(0, event_times)
res$c_i <- sapply(1:(length(event_times_ext)-1), function(i) {
  sum(df_raw$time > event_times_ext[i] & df_raw$time < event_times_ext[i+1] & df_raw$status == 0)
})

# Basic Rates
res$di <- res$d_i / res$n_i
res$pi <- 1 - res$di

# --- Kaplan-Meier (KM) ---
res$km_S <- cumprod(res$pi)
res$km_H <- -log(res$km_S)
se_km <- res$km_S * sqrt(cumsum(res$d_i / (res$n_i * (res$n_i - res$d_i))))
res$km_L <- pmax(0, res$km_S - 1.96 * se_km)
res$km_U <- pmin(1, res$km_S + 1.96 * se_km)

# --- Nelson-Aalen (NA) ---
res$NA_H <- cumsum(res$di)
res$NA_S <- exp(-res$NA_H)
# Variance of NA Hazard (Tsiatis formula)
se_na_h <- sqrt(cumsum(res$d_i / (res$n_i^2)))
# Log-transformed CI for Survival (ensures range 0 to 1)
res$NA_L <- exp(-(res$NA_H + 1.96 * se_na_h))
res$NA_U <- exp(-(res$NA_H - 1.96 * se_na_h))

