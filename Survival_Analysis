#Cochran-Mantel-Haenszel


# 1. Data Input (Based on the image provided)
# Group 1: Niacin, Group 2: Placebo
# n11: Success in Niacin, n21: Success in Placebo
n11 <- c(2, 4, 1, 1, 2)      # Niacin - Revascularization (Yes)
n12 <- c(46, 67, 86, 37, 92)  # Niacin - No Revascularization
n21 <- c(11, 12, 4, 6, 1)     # Placebo - Revascularization (Yes)
n22 <- c(41, 60, 76, 32, 93)  # Placebo - No Revascularization

# Marginal Totals for each stratum (j=1 to 5)
n1dot <- n11 + n12            # Total Niacin (n0 in your previous formula)
n2dot <- n21 + n22            # Total Placebo (n1 in your previous formula)
ndot1 <- n11 + n21            # Total Revascularization (d in your previous formula)
ndot2 <- n12 + n22            # Total No Revascularization
n     <- n1dot + n2dot        # Total sample size in each stratum (n in your formula)

# 2. Calculate Expected Value (E) and Variance (V) for each stratum
# Using the Hypergeometric Distribution formulas you provided:
# E(d0) = n0 * (d / n)
expected <- n1dot * (ndot1 / n)

# Var(d0) = [ n0 * n1 * d * (n - d) ] / [ n^2 * (n - 1) ]
variance <- (n1dot * n2dot * ndot1 * ndot2) / (n^2 * (n - 1))

# 3. Summing across all strata
sum_obs  <- sum(n11)          # Total observed successes in Niacin group
sum_exp  <- sum(expected)     # Total expected successes
sum_var  <- sum(variance)     # Total variance
diff     <- sum_obs - sum_exp # Total difference (O - E)

# 4. CMH Statistic Calculation
# Case A: Without Continuity Correction (Standard formula)
cmh_stat_raw <- (diff)^2 / sum_var

# Case B: With Continuity Correction (Used by R's mantelhaen.test by default)
# Formula: (|Sum(O-E)| - 0.5)^2 / Sum(Var)
cmh_stat_corrected <- (abs(diff) - 0.5)^2 / sum_var

# 5. Calculate P-values (df = 1)
p_val_raw <- 1 - pchisq(cmh_stat_raw, df = 1)
p_val_corrected <- 1 - pchisq(cmh_stat_corrected, df = 1)

# 6. Mantel-Haenszel Common Odds Ratio
# Formula: Sum(n11 * n22 / n) / Sum(n12 * n21 / n)
common_or <- sum(n11 * n22 / n) / sum(n12 * n21 / n)

# --- Output Results ---
cat("==========================================\n")
cat("  Manual CMH Test Calculation Results\n")
cat("==========================================\n")
cat("Sum of (Observed - Expected): ", round(diff, 4), "\n")
cat("Sum of Variances:             ", round(sum_var, 4), "\n\n")

cat("[Method 1: No Continuity Correction]\n")
cat("Chi-square Statistic:         ", round(cmh_stat_raw, 4), "\n")
cat("P-value:                      ", format.pval(p_val_raw), "\n\n")

cat("[Method 2: With Continuity Correction (R Default)]\n")
cat("Chi-square Statistic:         ", round(cmh_stat_corrected, 4), "\n")
cat("P-value:                      ", format.pval(p_val_corrected), "\n\n")

cat("Common Odds Ratio (MH):       ", round(common_or, 4), "\n")
cat("==========================================\n")




