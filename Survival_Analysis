# Weibull AFT Model with One Covariate (Step-Halving Newton-Raphson)
library(survival)

# 1. Data Preparation
# Converting Factor 'x' to Numeric (Maintained=0, Nonmaintained=1)
x_dummy <- ifelse(leukemia$x == "Nonmaintained", 1, 0)
y <- log(leukemia$time)
delta <- leukemia$status
n <- length(y)

# 2. Log-likelihood Function
log_lik <- function(beta, k) {
  mu <- beta[1] + beta[2] * x_dummy
  sigma <- 1/k
  log_sigma <- -log(k)
  w <- (y - mu) / sigma
  
  # Log-likelihood considering delta (censoring)
  val <- sum(delta * (w - log_sigma) - exp(w))
  return(val)
}

# 3. Score and Hessian Function
get_score_and_hessian <- function(beta, k) {
  mu <- beta[1] + beta[2] * x_dummy
  sigma <- 1/k
  log_sigma <- -log(k)
  w <- (y - mu) / sigma
  exp_w <- exp(w)
  
  # --- Score Vector ---
  s_beta0 <- (1/sigma) * sum(exp_w - delta)
  s_beta1 <- (1/sigma) * sum(x_dummy * (exp_w - delta))
  s_log_sigma <- sum(w * (exp_w - delta) - delta)
  score_vec <- c(s_beta0, s_beta1, s_log_sigma)
  
  # --- Hessian Matrix ---
  h_b0_b0 <- (-1/sigma^2) * sum(exp_w)
  h_b0_b1 <- (-1/sigma^2) * sum(x_dummy * exp_w)
  h_b1_b1 <- (-1/sigma^2) * sum(x_dummy^2 * exp_w)
  
  h_b0_ls <- (-1/sigma) * sum(w * exp_w + exp_w - delta)
  h_b1_ls <- (-1/sigma) * sum(x_dummy * (w * exp_w + exp_w - delta))
  h_ls_ls <- -sum(w^2 * exp_w + w * exp_w - w * delta)
  
  hessian_mat <- matrix(c(
    h_b0_b0, h_b0_b1, h_b0_ls,
    h_b0_b1, h_b1_b1, h_b1_ls,
    h_b0_ls, h_b1_ls, h_ls_ls
  ), 3, 3)
  
  return(list(score = score_vec, hessian = hessian_mat))
}

# 4. Optimization with Step-Halving
# Starting values: beta0=mean(y), beta1=0, k=1
current_beta <- c(mean(y), 0)
current_k <- 1.0
current_ll <- log_lik(current_beta, current_k)

cat("Starting robust Newton-Raphson with Step-Halving...\n\n")

for (i in 1:20) {
  sh <- get_score_and_hessian(current_beta, current_k)
  
  # Newton step direction
  step <- solve(sh$hessian) %*% sh$score
  
  # --- Step-Halving (Backtracking Line Search) ---
  lambda <- 1.0  # Initial step size
  repeat {
    trial_beta <- current_beta - lambda * step[1:2]
    trial_log_sigma <- -log(current_k) - lambda * step[3]
    trial_k <- exp(-trial_log_sigma)
    
    trial_ll <- log_lik(trial_beta, trial_k)
    
    # If likelihood improves or step is too small, accept the move
    if (trial_ll > current_ll || lambda < 1e-5) {
      current_beta <- trial_beta
      current_k <- trial_k
      current_ll <- trial_ll
      break
    }
    # Otherwise, half the step size
    lambda <- lambda * 0.5
  }
  
  cat(sprintf("Iteration %d (lambda=%.3f): Log-lik = %.4f, b0 = %.4f, b1 = %.4f, k = %.4f\n", 
              i, lambda, current_ll, current_beta[1], current_beta[2], current_k))
  
  # Convergence check based on score
  if (max(abs(sh$score)) < 1e-6) {
    cat("\nConverged!\n")
    break
  }
}

# 5. Final Results
final_log_sigma <- -log(current_k)
vcv <- solve(-sh$hessian)
se <- sqrt(diag(vcv))

results <- data.frame(
  Estimate = c(current_beta, final_log_sigma),
  Std_Error = se,
  row.names = c("(Intercept)", "xNonmaintained", "Log(scale)")
)
print(results)


