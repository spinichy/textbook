###############################################################################
#Manual for boxM


# 1. 데이터 준비
sparrows_data <- sparrows[, 2:6]
group <- sparrows$Survivorship

# 2. 각 그룹의 공분산 행렬 계산
cov_NS <- cov(sparrows_data[group == "NS", ])
cov_S  <- cov(sparrows_data[group == "S", ])

# 3. 그룹별 샘플 크기 및 자유도 계산
n1 <- sum(group == "NS")
n2 <- sum(group == "S")
df1 <- n1 - 1
df2 <- n2 - 1

# 4. 결합 공분산 행렬 (Pooled Covariance Matrix) 계산
pooled_cov <- ((df1 * cov_NS) + (df2 * cov_S)) / (df1 + df2)

# 5. Box's M 통계량 계산 (M = (n1+n2-2) * log|Sp| - (n1-1) * log|S1| - (n2-1) * log|S2|)
# We use determinant(x)$modulus to get log of the determinant
log_det_pool <- determinant(pooled_cov, logarithm = TRUE)$modulus
log_det_NS   <- determinant(cov_NS, logarithm = TRUE)$modulus
log_det_S    <- determinant(cov_S, logarithm = TRUE)$modulus

M <- (df1 + df2) * log_det_pool - (df1 * log_det_NS) - (df2 * log_det_S)

# 6. 카이제곱 통계량으로 변환 (Approximation)
# In simple cases, M follows a Chi-square distribution with degrees of freedom:
# df = (number of groups - 1) * (number of variables * (number of variables + 1) / 2)
p <- ncol(sparrows_data)
df_chi <- (2 - 1) * (p * (p + 1) / 2)

# Calculation of Chi-square value
chi_sq <- M * (1 - (2 * p^2 + 3 * p - 1) / (6 * (p + 1) * (2 - 1)) * (1/df1 + 1/df2 - 1/(df1 + df2)))

# 7. p-value 계산
p_val <- 1 - pchisq(chi_sq, df = df_chi)

# 결과 확인
cat("Chi-Square value:", chi_sq, "\n")
cat("P-value:", p_val, "\n")


