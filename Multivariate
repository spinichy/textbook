## Fctor Analysis (FA) - Minimum Residual - manual
#-------------------------------------------------------------------------------


# 1. Prepare Data
data_numeric <- euro_employment[, 3:11]
S_orig <- cor(data_numeric) 
p <- ncol(S_orig)
m <- 2 # Number of factors

# 2. Pure Initialization (No Eigendecomposition)
# Start with small random values to prove the algorithm converges on its own
set.seed(123)
Lambda <- matrix(runif(p * m, -0.1, 0.1), nrow = p, ncol = m)

# Parameters for Gradient Descent
learning_rate <- 0.05
iterations <- 3000

# 3. Iterative Estimation (Pure MinRes Gradient Descent)
# Goal: Minimize L = 0.5 * || (S - LL')_off ||^2
for (i in 1:iterations) {
  # Reconstruct model (S_model = Lambda * Lambda^T)
  Lambda_LambdaT <- Lambda %*% t(Lambda)
  
  # Calculate Residual Matrix (E = S - LL')
  E <- S_orig - Lambda_LambdaT
  
  # MinRes core logic: Focus only on off-diagonal elements
  diag(E) <- 0 
  
  # Calculate Gradient of Loss L = 0.5 * ||E||^2
  # Gradient w.r.t Lambda is -2 * E * Lambda
  gradient <- -2 * (E %*% Lambda)
  
  # Update Lambda using gradient descent
  Lambda <- Lambda - learning_rate * gradient
  
  # Monitoring convergence
  if (i %% 500 == 0) {
    loss <- 0.5 * sum(E^2)
    message(sprintf("Iteration %d: Loss = %f", i, loss))
  }
}

# 4. Final Results
colnames(Lambda) <- c("MR1", "MR2")
print("Final Factor Loadings (Lambda):")
print(Lambda)

# 5. Regression Weights & Factor Scores
# W = R^-1 * Lambda
W <- solve(S_orig) %*% Lambda
scaled_data <- scale(data_numeric)
factor_scores <- scaled_data %*% W

