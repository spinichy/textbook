##adjust p-value

# 1. Prepare variables and setup
vars_to_test <- c("Total_length", "Alar_extent", "L_beak_head", "L_humerus", "L_keel_sternum")
alpha <- 0.05

# 2. Perform Welch's t-tests and get raw p-values
p_values <- sapply(vars_to_test, function(var) {
  formula <- as.formula(paste(var, "~ Survivorship"))
  t_test <- t.test(formula, data = sparrows, var.equal = FALSE)
  return(t_test$p.value)
})

# 3. Calculate adjusted p-values for each method
p_adj_bonf  <- p.adjust(p_values, method = "bonferroni")
p_adj_holm  <- p.adjust(p_values, method = "holm")
p_adj_hoch  <- p.adjust(p_values, method = "hochberg")
p_adj_sidak <- 1 - (1 - p_values)^length(p_values)

# 4. Create a comprehensive result table for each method
# Each method is evaluated against the alpha level of 0.05
results_detailed <- data.frame(
  Variable    = vars_to_test,
  Raw_p       = round(p_values, 5),
  Bonferroni  = ifelse(p_adj_bonf < alpha, "Reject H0", "Fail to Reject"),
  Holm        = ifelse(p_adj_holm < alpha, "Reject H0", "Fail to Reject"),
  Hochberg    = ifelse(p_adj_hoch < alpha, "Reject H0", "Fail to Reject"),
  Sidak       = ifelse(p_adj_sidak < alpha, "Reject H0", "Fail to Reject")
)

# 5. Display the final decision matrix
print(results_detailed)



