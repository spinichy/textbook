# Function to perform tests for a single PC
perform_tests <- function(pc_name) {
  formula <- as.formula(paste(pc_name, "~ Survivorship"))
  
  # t-test (assuming equal variance = FALSE for Welch's t-test)
  t_res <- t.test(formula, data = sparrows_pca, var.equal = FALSE)
  
  # F-test for equality of variances
  f_res <- var.test(formula, data = sparrows_pca)
  
  # Levene's test (based on median)
  lev_res <- leveneTest(formula, data = sparrows_pca, center = median)
  
  return(data.frame(
    PC = pc_name,
    t_pvalue = t_res$p.value,
    f_pvalue = f_res$p.value,
    levene_pvalue = lev_res$`Pr(>F)`[1]
  ))
}

# 3. Apply the function to all PCs and combine results
test_results <- do.call(rbind, lapply(pcs, perform_tests))

