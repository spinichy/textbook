## Fctor Analysis (FA) - MLE - manual
#-------------------------------------------------------------------------------


# 1. Prepare Data
data_numeric <- euro_employment[, 3:11]
S <- cor(data_numeric) 
p <- ncol(S)
m <- 2 

# 2. Initialization
set.seed(123)
Lambda <- matrix(runif(p * m, -0.1, 0.1), nrow = p, ncol = m)
Psi <- diag(rep(0.5, p)) # Uniqueness matrix

# Parameters (Learning rate reduced for stability)
learning_rate <- 0.001
iterations <- 3000

# 3. Iterative Estimation (Stable MLE Gradient Descent)
for (i in 1:iterations) {
  # Sigma reconstruction
  Sigma <- (Lambda %*% t(Lambda)) + Psi
  
  # Numerical Stability: Add a tiny value to diagonal (Ridge regularization)
  Sigma_reg <- Sigma + diag(1e-6, p)
  Sigma_inv <- solve(Sigma_reg)
  
  # Gradient of f w.r.t Lambda
  # Formula: 2 * Sigma^-1 * (Sigma - S) * Sigma^-1 * Lambda
  gradient_lambda <- 2 * Sigma_inv %*% (Sigma - S) %*% Sigma_inv %*% Lambda
  
  # Update Lambda
  Lambda <- Lambda - learning_rate * gradient_lambda
  
  # Update Psi with constraint (Psi must be > 0, set lower bound 0.01)
  diag_vals <- diag(Sigma_inv %*% S %*% Sigma_inv)
  Psi_new <- diag(pmax(1 / diag_vals, 0.01))
  Psi <- Psi * 0.9 + Psi_new * 0.1 # Smoothing update
  
  if (i %% 500 == 0) {
    obj <- log(det(Sigma)) + sum(diag(S %*% Sigma_inv))
    message(sprintf("Iteration %d: Objective Value = %f", i, obj))
  }
}

# 4. Final Results
colnames(Lambda) <- c("ML1", "ML2")
print("Final MLE Factor Loadings:")
print(Lambda)

# 5. Factor Scores (Bartlett's method)
# Weights = Sigma^-1 * Lambda
W <- solve((Lambda %*% t(Lambda)) + Psi) %*% Lambda
scaled_data <- scale(data_numeric)
factor_scores <- scaled_data %*% W

# 6. Visualization
fs_df <- as.data.frame(factor_scores)
fs_df$Country <- euro_employment$Country

ggplot(fs_df, aes(x = ML1, y = ML2, label = Country)) +
  geom_point(color = "darkgreen", size = 3) +
  geom_text(vjust = 1.5, size = 3) +
  geom_vline(xintercept = 0, linetype = "dashed") +
  geom_hline(yintercept = 0, linetype = "dashed") +
  theme_minimal() +
  labs(title = "Stable MLE Factor Analysis Plot", x = "ML1", y = "ML2")



