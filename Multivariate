# Multivariate Van Valen Test using Euclidean distance
# 1. Prepare data and grouping
data_mat <- sparrows[, 2:6]
group_var <- sparrows$Survivorship

# 2. Calculate group medians for each variable
medians_mat <- aggregate(data_mat, by = list(group = group_var), FUN = median)[,-1]
# 3. Calculate Euclidean distance of each observation from its group median
dist_from_median <- numeric(nrow(data_mat))

for(i in 1:nrow(data_mat)) {
  # Find the median vector corresponding to the observation's group
  med_vec <- medians_mat[which(levels(group_var) == group_var[i]), ]
  # Calculate Euclidean distance
  dist_from_median[i] <- sqrt(sum((data_mat[i, ] - med_vec)^2))
}

# 4. Perform a t-test on the calculated distances
# If p > 0.05, it suggests homogeneous multivariate dispersion
multivariate_van_valen <- t.test(dist_from_median ~ group_var)
print(multivariate_van_valen)



