#Canovical Correlation Analysis, "CCA" - Manual

##------------------------------------------------------------------------------


# Load required libraries
library(CCA)

# Data preparation
pop <- LifeCycleSavings[, 2:3]
eco <- LifeCycleSavings[, -c(2:3)]

# Step 1: Compute covariance matrices
# ------------------------------------------------------------
S_XX <- cov(pop)
S_YY <- cov(eco)
S_XY <- cov(pop, eco)
S_YX <- cov(eco, pop)

# Step 2: Solve the generalized eigenvalue problem used by cc()
# ------------------------------------------------------------
# Matrix M = S_XX^(-1) * S_XY * S_YY^(-1) * S_YX
M <- solve(S_XX) %*% S_XY %*% solve(S_YY) %*% S_YX
eigen_result <- eigen(M)

# First eigenvector and canonical correlation
a_raw <- eigen_result$vectors[, 1]
rho <- sqrt(eigen_result$values[1])

# Step 3: Apply the exact normalization constraint used in CCA::cc()
# ------------------------------------------------------------
# cc() normalizes a so that t(a) * S_XX * a = 1
scaling_factor <- sqrt(t(a_raw) %*% S_XX %*% a_raw)
a_normalized <- a_raw / as.numeric(scaling_factor)

# Compute corresponding Y weights (b)
b_raw <- (1 / rho) * solve(S_YY) %*% S_YX %*% a_normalized

# Step 4: Output results
# ------------------------------------------------------------
print("Manual Exact-Matching X Weights:")
print(a_normalized)

print("Manual Exact-Matching Y Weights:")
print(b_raw)

print(paste("Canonical Correlation:", rho))


# Step 5: Verify with the official cc() function
# ------------------------------------------------------------
cc_result <- cc(X = pop, Y = eco)

print("Official cc() X Weights:")
print(cc_result$xcoef[, 1])

print("Official cc() Y Weights:")
print(cc_result$ycoef[, 1])
