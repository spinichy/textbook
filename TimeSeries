# 1. Prepare data (Assuming icecream_total is already defined)
sales_vector <- as.numeric(icecream_total[1, -1])
n <- length(sales_vector)
m <- 4 # Quarterly seasonality

# 2. Initialization
L_init <- mean(sales_vector[1:m])
T_init <- (mean(sales_vector[(m+1):(2*m)]) - mean(sales_vector[1:m])) / m
S_init <- sales_vector[1:m] / L_init

# 3. Define objective function (SSE)
hw_sse <- function(params, data, m) {
  alpha <- params[1]; beta <- params[2]; gamma <- params[3]
  L <- numeric(length(data)); T <- numeric(length(data)); S <- numeric(length(data))
  L[m] <- L_init; T[m] <- T_init; S[1:m] <- S_init
  
  sse <- 0
  for (t in (m + 1):length(data)) {
    L[t] <- alpha * (data[t] / S[t-m]) + (1 - alpha) * (L[t-1] + T[t-1])
    T[t] <- beta * (L[t] - L[t-1]) + (1 - beta) * T[t-1]
    S[t] <- gamma * (data[t] / L[t]) + (1 - gamma) * S[t-m]
    prediction <- (L[t-1] + T[t-1]) * S[t-m]
    sse <- sse + (data[t] - prediction)^2
  }
  return(sse)
}

# 4. Optimize parameters
opt <- optim(par = c(0.2, 0.1, 0.3), fn = hw_sse, data = sales_vector, m = m,
             method = "L-BFGS-B", lower = 0.001, upper = 0.999)

# 5. Extract final states
best_alpha <- opt$par[1]; best_beta <- opt$par[2]; best_gamma <- opt$par[3]
L <- numeric(n); T <- numeric(n); S <- numeric(n)
L[m] <- L_init; T[m] <- T_init; S[1:m] <- S_init
for (t in (m + 1):n) {
  L[t] <- best_alpha * (sales_vector[t] / S[t-m]) + (1 - best_alpha) * (L[t-1] + T[t-1])
  T[t] <- best_beta * (L[t] - L[t-1]) + (1 - best_beta) * T[t-1]
  S[t] <- best_gamma * (sales_vector[t] / L[t]) + (1 - best_gamma) * S[t-m]
}

# 6. Future forecasting (20 quarters)
