analyze_transport_stl <- function(ts_data, title_name, y_label) {
  
  # Step 1: Apply Log transformation to stabilize expanding seasonal variance
  log_ts <- log(ts_data)
  
  # Step 2: Run STL decomposition
  # s.window = "periodic" enforces a stable, unchanging seasonal pattern over years.
  # robust = TRUE activates the outer loop to downweight massive shocks like 9/11.
  stl_result <- stl(log_ts, s.window = "periodic", robust = TRUE)
  
  # Step 3: Extract isolated components from the STL model
  trend_comp    <- stl_result$time.series[, "trend"]
  seasonal_comp <- stl_result$time.series[, "seasonal"]
  
  # Step 4: Calculate Deseasonalized Data (Trend + Remainder)
  deseasonalized_ts <- log_ts - seasonal_comp
  
  # Step 5: Plotting the comprehensive overview
  plot(log_ts, col = "gray70", lwd = 1,
       main = paste(title_name, ": Log-Scale STL Analysis"), 
       ylab = paste("Log(", y_label, ")", sep=""), xlab = "Time")
  
  # Overlay the clean, low-pass filtered STL Trend line (Red)
  lines(trend_comp, col = "red", lwd = 2.5)
  
  # Overlay the Deseasonalized data (Blue dashed line: Trend + Remainder)
  lines(deseasonalized_ts, col = "blue", lty = 2, lwd = 1.2)
  
  # Add legend for clarity
  legend("bottomleft", 
         legend = c("Log Original (With Seasonality)", "STL Trend Line (Clean)", "Deseasonalized (Trend + Remainder)"),
         col = c("gray70", "red", "blue"), 
         lty = c(1, 1, 2), 
         lwd = c(1, 2.5, 1.2), 
         bg = "white", cex = 0.8)
  
  # Return the STL object for further diagnostic inspections if needed
  return(stl_result)
}


