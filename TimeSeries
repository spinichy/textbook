# Load required library
library(ggplot2)

# 1. Load the dataset from the CSV file
DepartmentStoreSales <- read.csv(file = "DepartmentStoreSales.csv", header = TRUE)

# 2. Convert the dataframe column to a time series object
# Frequency = 4 specifies quarterly data starting from Q1 2002
sales_ts <- ts(DepartmentStoreSales$Sales, start = c(2002, 1), frequency = 4)

# 3. Perform STL Decomposition
stl_fit <- stl(sales_ts, s.window = "periodic")

# 4. Extract components into a dataframe for ggplot2
stl_df          <- as.data.frame(stl_fit$time.series)
stl_df$Observed <- as.numeric(sales_ts)

# Store the original text labels and create a numeric sequence for ordering
stl_df$Quarter  <- DepartmentStoreSales$Quarter
stl_df$Index    <- 1:nrow(stl_df)

# 5. Reshape into long format to utilize ggplot's facetting function
plot_data <- data.frame(
  Quarter   = rep(stl_df$Quarter, 4),
  Index     = rep(stl_df$Index, 4),
  Value     = c(stl_df$Observed, stl_df$trend, stl_df$seasonal, stl_df$remainder),
  Component = factor(rep(c("Observed", "Trend", "Seasonal", "Remainder"), each = nrow(stl_df)),
                     levels = c("Observed", "Trend", "Seasonal", "Remainder"))
)

# 6. Calculate the unified data range to define the scale bar height
# The bar height matches the range of the component with the smallest variation
min_range <- min(
  diff(range(stl_df$Observed)),
  diff(range(stl_df$trend)),
  diff(range(stl_df$seasonal)),
  diff(range(stl_df$remainder))
)

# 7. Create a data frame for the variance bars positioned on the left side
# Place bars slightly before the first index (x = 0) to separate from the line plot
bar_data <- data.frame(
  Component = factor(c("Observed", "Trend", "Seasonal", "Remainder"),
                     levels = c("Observed", "Trend", "Seasonal", "Remainder")),
  xmin = 0.1,
  xmax = 0.5
)

# Set specific top and bottom limits for each bar based on its component's center
bar_data$ymin <- c(mean(stl_df$Observed), mean(stl_df$trend), mean(stl_df$seasonal), mean(stl_df$remainder)) - (min_range / 2)
bar_data$ymax <- c(mean(stl_df$Observed), mean(stl_df$trend), mean(stl_df$seasonal), mean(stl_df$remainder)) + (min_range / 2)

# 8. Create the multi-panel plot with full x-axis labels rotated 45 degrees
ggplot() +
  # Draw the time series line data using Index for continuous path tracking
  geom_line(data = plot_data, aes(x = Index, y = Value), color = "steelblue", size = 0.8) +
  # Draw the variance indicator bars on the left margin
  geom_rect(data = bar_data, aes(xmin = xmin, xmax = xmax, ymin = ymin, ymax = ymax), 
            fill = "gray60", color = "gray40", alpha = 0.7) +
  # Separate into vertical panels with free y-axes
  facet_wrap(~ Component, ncol = 1, scales = "free_y") +
  # Map the numeric indices directly to the original "Q1-2002" string labels
  scale_x_continuous(
    breaks = stl_df$Index,
    labels = stl_df$Quarter,
    expand = expansion(mult = c(0.05, 0.02))
  ) +
  labs(title = "STL Decomposition with DepartmentStoreSales",
       x = "Quarter",
       y = "Value") +
  theme_minimal() +
  theme(
    strip.text = element_text(face = "bold", size = 11),
    plot.title = element_text(face = "bold", size = 14, hjust = 0.5),
    panel.grid.minor = element_blank(),
    # Rotate x-axis labels by 45 degrees and align them cleanly to the tick marks
    axis.text.x = element_text(angle = 45, hjust = 1, vjust = 1, size = 9)
  )


