# [Manual QS-Test Calculation]
# We calculate the autocorrelation up to a specific lag and use the sum 
# to approximate the QS-test statistic.

# 1. Ensure data is prepared (monthly_returns object from previous step)
clean_data <- as.numeric(monthly_returns)
n <- length(clean_data)
s <- 12 # Monthly frequency

# 2. Calculate autocorrelation for each lag up to s-1
# This mirrors how QS-test evaluates seasonal patterns across cycles
lags <- 1:(s - 1)
rho_k <- sapply(lags, function(k) {
  y1 <- clean_data[(k + 1):n]
  y2 <- clean_data[1:(n - k)]
  cor(y1, y2)
})

# 3. Calculate the QS statistic: n * sum(rho_k^2)
# This represents the cumulative seasonal signal
qs_stat_manual <- n * sum(rho_k^2)

# 4. Calculate p-value based on Chi-square distribution (df = s-1)
p_val_manual <- pchisq(q = qs_stat_manual, df = s - 1, lower.tail = FALSE)

# 5. Output the results
print(paste("Manual QS-Test Statistic:", round(qs_stat_manual, 4)))
print(paste("Manual QS-Test p-value:", round(p_val_manual, 4)))



