pacf(data_diff, main = "PACF for AR order")
acf(data_diff, main = "ACF for MA order")

# 5. Step 3: Build ARIMA model
# If manual order causes non-stationary errors, use ML method 
# or use auto.arima() to find the optimal order automatically
# Using auto.arima for better stability and performance
