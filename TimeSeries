# Load required library
library(forecast)

# 1. Prepare data
data("airmiles")
y <- as.numeric(airmiles)
n <- length(y)
time_index <- 1:n

# 2. Estimate initial parameters (L0, B0) using Linear Regression
initial_model <- lm(y ~ time_index)
L0_start <- coef(initial_model)[1]
B0_start <- coef(initial_model)[2]

# 3. Define the objective function for optimization (SSE)
holt_sse <- function(params) {
  alpha <- params[1]
  beta <- params[2]
  
  # Ensure parameters are within valid range [0, 1]
  if(alpha < 0 || alpha > 1 || beta < 0 || beta > 1) return(Inf)
  
  level <- numeric(n)
  trend <- numeric(n)
  
  # Set initial states
  level[1] <- L0_start
  trend[1] <- B0_start
  
  # Recursive calculation
  for (t in 2:n) {
    level[t] <- alpha * y[t] + (1 - alpha) * (level[t-1] + trend[t-1])
    trend[t] <- beta * (level[t] - level[t-1]) + (1 - beta) * trend[t-1]
  }
  
  # Calculate One-step-ahead forecast errors
  pred <- c(NA, level[1:(n-1)] + trend[1:(n-1)])
  sse <- sum((y[2:n] - pred[2:n])^2, na.rm = TRUE)
  return(sse)
}

# 4. Optimize Alpha and Beta
opt_result <- optim(par = c(0.5, 0.5), fn = holt_sse, method = "L-BFGS-B", 
                    lower = c(0, 0), upper = c(1, 1))

best_alpha <- opt_result$par[1]
best_beta <- opt_result$par[2]

# 5. Calculate final states with optimized parameters
final_level <- numeric(n)
final_trend <- numeric(n)
final_level[1] <- L0_start
final_trend[1] <- B0_start

for (t in 2:n) {
  final_level[t] <- best_alpha * y[t] + (1 - best_alpha) * (final_level[t-1] + final_trend[t-1])
  final_trend[t] <- best_beta * (final_level[t] - final_level[t-1]) + (1 - best_beta) * final_trend[t-1]
}

# 6. Forecast for H = 5
h_steps <- 1:5
forecasts <- final_level[n] + h_steps * final_trend[n]

# 7. Print results
cat("Optimized Alpha:", round(best_alpha, 4), "\n")
cat("Optimized Beta: ", round(best_beta, 4), "\n")
