# 3. Combine Actual and Forecast data for comparison
plot_df <- bind_rows(actual_df, forecast_df) %>%
  # Filter to match the periods available in the actual data
  filter(Period %in% actual_df$Period)

# 4. Visualization: Bar chart comparing Actual vs Forecast
ggplot(plot_df, aes(x = Period, y = Sales, fill = Type)) +
  geom_bar(stat = "identity", position = "dodge") +
  # Add text labels on top of bars
  geom_text(aes(label = comma(round(Sales, 0))), 
            position = position_dodge(width = 0.9), vjust = -0.5, size = 3) +
  # Format y-axis with commas and set color scheme
  scale_y_continuous(labels = label_comma()) +
  scale_fill_manual(values = c("Actual" = "steelblue", "Forecast" = "firebrick")) +
  labs(
    title = "Actual Sales vs Prophet Forecast (2020-2024)",
    x = "Half-Year Period", 
    y = "Sales Volume (KRW)"
  ) +
  theme_minimal() +
  theme(
    legend.position = "bottom",
    axis.text.x = element_text(angle = 45, hjust = 1)
  )


