# 1. Base R: Date, POSIXct, POSIXlt
date_val <- as.Date("2026-05-07")
ct_val   <- as.POSIXct("2026-05-07 12:00:00")
lt_val   <- as.POSIXlt("2026-05-07 12:00:00")

print(unclass(date_val)) # Days since 1970-01-01
print(as.numeric(ct_val)) # Seconds since 1970-01-01
print(unclass(lt_val)) # List of year, month, day, etc.

# 2. zoo: yearmon, yearqtr
ym_val <- as.yearmon("2026-05")
yq_val <- as.yearqtr("2026-2")

print(as.numeric(ym_val)) # 2026 + (5-1)/12
print(as.numeric(yq_val)) # 2026 + (2-1)/4

# 3. hms: Time only
time_val <- as_hms("12:00:00")
print(as.numeric(time_val)) # Seconds since midnight

# 4. nanotime: Nano-seconds precision
# Requires 64-bit integer support
nano_val <- nanotime("2026-05-07T12:00:00.000000001+00:00")
print(nano_val)

# 5. lubridate: Period vs Duration
# Period: Intuitive time units
per_val <- months(1) 
# Duration: Exact physical seconds
dur_val <- dweeks(1) 

print(unclass(per_val))
print(as.numeric(dur_val)) # Seconds in a week

# 6. tsibble: yearmonth (Tidy style)
tm_val <- yearmonth("2026 May")
print(as.numeric(tm_val)) # Number of months since 1970 Jan





# Load necessary libraries
if (!require("pacman")) install.packages("pacman")
pacman::p_load(zoo, hms, nanotime, lubridate, tsibble, bit64)

# 1. Base R: Standard Date & Time
# 
date_val <- as.Date("2026-05-07")
ct_val   <- as.POSIXct("2026-05-07 16:30:05")
lt_val   <- as.POSIXlt("2026-05-07 16:30:05")

print(date_val)  # "2026-05-07"
print(ct_val)    # "2026-05-07 16:30:05 KST"
print(lt_val)    # Looks same as ct, but it's a list under the hood

# 2. zoo: Monthly & Quarterly (Simplified view)
# Useful for reports and clean plots
ym_val <- as.yearmon("2026-05")
yq_val <- as.yearqtr("2026-2")

print(ym_val)    # "5월 2026" (or "May 2026" depending on locale)
print(yq_val)    # "2026 Q2"

# 3. hms: Time only (No date attached)
time_val <- as_hms("16:30:05")
print(time_val)  # "16:30:05"

# 4. nanotime: Ultra-precision
# Shows nanoseconds which POSIXct usually hides
nano_val <- nanotime("2026-05-07T16:30:05.123456789+09:00")
print(nano_val)  # "2026-05-07T07:30:05.123456789+00:00" (UTC display)

# 5. lubridate: Calculated Periods
# Not a point in time, but a 'span' of time
my_duration <- ddays(1) + dhours(5) # Exact physical time
my_period   <- days(1) + hours(5)   # Human-readable time

print(my_duration) # "97200s (~1.12 days)"
print(my_period)   # "1d 5H 0M 0S"

# 6. tsibble: Tidy Time Index
tm_val <- yearmonth("2026 May")
print(tm_val)    # "2026 5월" (Optimized for tsibble objects)



