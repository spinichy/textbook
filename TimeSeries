  # --- Monthly Cumulative Sum ---
  group_by(year, month) %>%
  mutate(cum_sum_monthly = cumsum(value)) %>%
  
  # --- Quarterly Cumulative Sum ---
  group_by(year, quarter) %>%
  mutate(cum_sum_quarterly = cumsum(value)) %>%
  
  # --- Yearly Cumulative Sum (YTD) ---
  group_by(year) %>%
  mutate(cum_sum_yearly = cumsum(value)) %>%
  
  # Ungroup at the end to avoid side effects
  ungroup()

