# 2. Define parameters (alpha: level, beta: trend)
# These values are usually optimized; here we set them manually for demonstration
alpha <- 0.5
beta  <- 0.1

# 3. Initialize level and trend
# Starting level (l) as the first observation, starting trend (b) as difference
l <- numeric(n)
b <- numeric(n)
l[1] <- y[1]
b[1] <- y[2] - y[1]

# 4. Implement Holt's recursion logic
# We iterate through the data to update level and trend at each step
for (t in 2:n) {
  l[t] <- alpha * y[t] + (1 - alpha) * (l[t-1] + b[t-1])
  b[t] <- beta * (l[t] - l[t-1]) + (1 - beta) * b[t-1]
}

# 5. Calculate one-step-ahead forecast
# The forecast at t is the combination of level and trend from t-1
y_hat <- c(NA, l[1:(n-1)] + b[1:(n-1)])

