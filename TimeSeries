# Load necessary libraries
if (!require("pacman")) install.packages("pacman")
pacman::p_load(lubridate, zoo)

# 1. Parsing Practice: Converting various strings to Date/Time objects
# Use specific format symbols to match the input string structure exactly

# Case A: Standard dash format with time
str_a <- "2026-05-07 16:45:30"
dt_a <- as.POSIXct(str_a, format = "%Y-%m-%d %H:%M:%S");dt_a 
# English: %Y is 4-digit year, %H is 24-hour format

# Case B: Slash format with 2-digit year
str_b <- "07/05/26"
dt_b <- as.Date(str_b, format = "%d/%m/%y");dt_b
# English: %y (lowercase) represents a 2-digit year

# Case C: Month name and literal text
# English: Switching time locale to English for parsing month names
if (.Platform$OS.type == "windows") {
  Sys.setlocale("LC_TIME", "English")
} else {
  Sys.setlocale("LC_TIME", "en_US.UTF-8")
}

str_c <- "May 07, 2026"
dt_c <- as.Date(str_c, format = "%B %d, %Y");dt_c
# English: %B matches the full month name

# 2. Formatting Practice: Converting objects back to customized strings
# This is useful for creating clean labels for plots or reports

now <- Sys.time()

# Format 1: Military / Technical style
fmt_1 <- format(now, "%Y%m%d_%H%M%S");fmt_1
# English: Output example "20260507_164530"

# Format 2: Human-readable with weekdays
fmt_2 <- format(now, "%A, %d of %B, %Y");fmt_2
# English: Output example "Thursday, 07 of May, 2026"

# Format 3: 12-hour clock with AM/PM
fmt_3 <- format(now, "%I:%M %p");fmt_2
# English: %I is 12-hour clock, %p is AM/PM indicator

# 3. Component Extraction: Using POSIXlt for deep diving
lt_now <- as.POSIXlt(now);lt_now

# English: POSIXlt stores components in a list format
year_val  <- lt_now$year + 1900  # English: Years are counted from 1900
month_val <- lt_now$mon + 1      # English: Months are 0-indexed (0=Jan)
wday_val  <- lt_now$wday         # English: Day of week (0-6, 0=Sunday)

# 4. Lubridate shortcuts: The easier way to format
# English: No need for % symbols; just specify the order of Y, M, and D
easy_date <- ymd("20260507")
easy_dt   <- mdy_hm("May 07, 2026 16:45")

# 5. Displaying underlying numeric values for practice
# English: Checking the raw data stored behind the formatted display
cat("Formatted:", format(now, "%Y-%m-%d %H:%M:%S"), "\n")
cat("Numeric (seconds since 1970):", as.numeric(now), "\n")
