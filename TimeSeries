# [KPSS Test]
# Null Hypothesis (H0): The series is stationary.
# Alternative Hypothesis (H1): The series is non-stationary (has a unit root).
kpss_test <- ur.kpss(as.numeric(daily_returns))

# [Display Results]
summary(kpss_test)


# [Data Preparation]
# Let y be the return series (already defined as daily_returns)
y <- as.numeric(daily_returns)
n <- length(y)
t <- 1:n

# 1. Detrending: Regress y on time (y = alpha + beta*t + e)
# We use linear regression to remove the trend
model <- lm(y ~ t)
e <- residuals(model)

# 2. Calculate Partial Sums (S_t)
# S_t is the cumulative sum of residuals
S <- cumsum(e)

# 3. Estimate Long-run Variance (sigma_epsilon^2)
# Using Newey-West estimator (simplified version)
# We calculate variance of residuals with a lag adjustment
# For simplicity, we use the sample variance as a baseline
sigma2_hat <- sum(e^2) / n 

# 4. Calculate LM Statistic
# Formula: LM = (1/T^2) * sum(S_t^2) / sigma_hat^2
LM <- (1 / n^2) * sum(S^2) / sigma2_hat

# 5. Output Result
print(paste("Manual KPSS LM Statistic:", round(LM, 4)))

# Note: The critical values for KPSS test are fixed (e.g., 0.463 for 5% level)
# If LM > 0.463, reject the Null Hypothesis (Stationary)
if(LM > 0.463) {
  print("Result: Reject H0 (Series is Non-stationary)")
} else {
  print("Result: Fail to reject H0 (Series is Stationary)")
}



