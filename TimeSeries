    # --- Calculating Differences directly using diff() ---
    # Note: diff() returns a vector shorter than the original, 
    # so we pad it with NA at the beginning to match the dataframe length.
    mom_diff_base = c(rep(NA, 1), diff(value, lag = 1)),
    qoq_diff_base = c(rep(NA, 3), diff(value, lag = 3)),
