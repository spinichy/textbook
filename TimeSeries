# 3. Define a robust forecasting function
forecast_category <- function(category_name, model_type, is_damped = FALSE) {
  # Extract and sort time series
  ts_data <- plot_data %>% 
    filter(구분 == category_name) %>% 
    arrange(Period) %>% 
    pull(Sales) %>% 
    ts(frequency = 4, start = c(2011, 4))
  
  # Fit ETS model
  fit <- ets(ts_data, model = model_type, damped = is_damped)
  fc <- forecast(fit, h = 20)
  
  # Extract time indices safely
  # Create a sequence of quarters
  history_time <- time(ts_data)
  forecast_time <- seq(from = end(ts_data)[1] + end(ts_data)[2]/4, 
                       by = 0.25, length.out = 21)[-1]
  
  history_df <- data.frame(
    Date = as.numeric(history_time),
    Sales = as.numeric(ts_data),
    Type = "History",
    구분 = category_name
  )
  
  forecast_df <- data.frame(
    Date = as.numeric(forecast_time),
    Sales = as.numeric(fc$mean),
    Type = "Forecast",
    구분 = category_name
  )
  
  return(rbind(history_df, forecast_df))
}

